nt(\"\\n\" + \"=\"*130)\nprint(f\"✅ 成功获取 {len(df_result)} 只股票的实时数据\")\nprint(f\"⏰ 数据时间：收盘后\")\nprint(f\"📈 数据来源：Tushare API (交易所实时推送)\")\nprint(\"=\"*130)\nEOF\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-35b-a3b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773049723678}}
