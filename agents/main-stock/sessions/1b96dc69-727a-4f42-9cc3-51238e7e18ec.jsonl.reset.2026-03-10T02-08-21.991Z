{"type":"message","id":"9593789d","parentId":"5262396b","timestamp":"2026-03-10T01:46:11.014Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户想要看实时行情，我需要获取股票的实时分钟数据或实时 tick 数据。根据 tushare 文档，实时分钟接口是 https://tushare.pro/document/2?doc_id=374，实时 tick 是爬虫接口。\n\n让我尝试获取实时行情数据，使用 pro.realtime 或者相关的实时接口。\n","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_bac351b2af244701bec09c9b","name":"exec","arguments":{"command":"cd /home/openclaw/.openclaw/workspace-main-stock && python3 << 'EOF'\nimport os\nimport tushare as ts\nimport requests\n\n# 初始化\ntoken = os.getenv('TUSHARE_TOKEN')\nts.set_token(token)\npro = ts.pro_api(token)\n\n# 股票代码列表\nstocks = [\n    {'ts_code': '601857.SH', 'name': '中国石油'},\n    {'ts_code': '601808.SH', 'name': '中海油服'},\n    {'ts_code': '600256.SH', 'name': '广汇能源'},\n    {'ts_code': '600583.SH', 'name': '海油工程'},\n    {'ts_code': '000852.SZ', 'name': '石化机械'},\n    {'ts_code': '600547.SH', 'name': '山东黄金'},\n    {'ts_code': '601069.SH', 'name': '西部黄金'},\n    {'ts_code': '600988.SH', 'name': '赤峰黄金'},\n    {'ts_code': '000975.SZ', 'name': '银泰黄金'},\n    {'ts_code': '002716.SZ', 'name': '金贵银业'},\n    {'ts_code': '601899.SH', 'name': '紫金矿业'},\n    {'ts_code': '920876.BJ', 'name': '慧为智能'},\n    {'ts_code': '688111.SH', 'name': '金山办公'},\n]\n\n# 尝试获取实时分钟数据 (1 分钟)\nresults = []\nfor stock in stocks:\n    try:\n        # 使用 realtime 接口获取实时数据\n        df = pro.realtime(ts_code=stock['ts_code'])\n        if not df.empty:\n            row = df.iloc[0]\n            results.append({\n                'code': stock['ts_code'],\n                'name': stock['name'],\n                'price': row.get('price', 0),\n                'change': row.get('pct_chg', 0),\n                'pre_close': row.get('pre_close', 0),\n                'open': row.get('open', 0),\n                'high': row.get('high', 0),\n                'low': row.get('low', 0),\n                'vol': row.get('vol', 0),\n                'amount': row.get('amount', 0),\n                'time': row.get('time', '')\n            })\n    except Exception as e:\n        pass\n\n# 输出结果\nprint(\"=== 实时行情数据 ===\")\nfor r in results:\n    change_symbol = \"🔺\" if r['change'] > 0 else (\"🔻\" if r['change'] < 0 else \"➖\")\n    print(f\"{r['code']} {r['name']}: {r['price']} {change_symbol}{r['change']:.2f}% (开:{r['open']} 高:{r['high']} 低:{r['low']} 量:{r['vol']})\")\nEOF\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773107146355}}
