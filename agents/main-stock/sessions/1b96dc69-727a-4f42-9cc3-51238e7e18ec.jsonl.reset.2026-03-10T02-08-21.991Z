{"type":"message","id":"01cc3588","parentId":"e7f98d07","timestamp":"2026-03-10T02:03:03.803Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"用户想要查看实时行情数据。我需要从同花顺获取所有自选股的实时数据。让我通过浏览器访问同花顺页面获取实时行情。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_4def384c43e346298a8cab67","name":"exec","arguments":{"command":"cd /home/openclaw/.openclaw/workspace-main-stock && python3 << 'EOF'\nimport requests\nimport re\nfrom datetime import datetime\n\n# 股票代码列表\nstocks = [\n    {'code': '601857', 'name': '中国石油', 'market': 'sh'},\n    {'code': '601808', 'name': '中海油服', 'market': 'sh'},\n    {'code': '600256', 'name': '广汇能源', 'market': 'sh'},\n    {'code': '600583', 'name': '海油工程', 'market': 'sh'},\n    {'code': '000852', 'name': '石化机械', 'market': 'sz'},\n    {'code': '600547', 'name': '山东黄金', 'market': 'sh'},\n    {'code': '601069', 'name': '西部黄金', 'market': 'sh'},\n    {'code': '600988', 'name': '赤峰黄金', 'market': 'sh'},\n    {'code': '000975', 'name': '银泰黄金', 'market': 'sz'},\n    {'code': '002716', 'name': '金贵银业', 'market': 'sz'},\n    {'code': '601899', 'name': '紫金矿业', 'market': 'sh'},\n    {'code': '920876', 'name': '慧为智能', 'market': 'bj'},\n    {'code': '688111', 'name': '金山办公', 'market': 'sh'},\n]\n\nprint(f\"=== 实时行情数据 ===\")\nprint(f\"获取时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\nprint()\n\nresults = []\nfor stock in stocks:\n    try:\n        # 同花顺实时行情接口\n        if stock['market'] == 'sh':\n            url = f\"https://d.10jqka.com.cn/v6/quote/hs_{stock['code']}.js\"\n        elif stock['market'] == 'sz':\n            url = f\"https://d.10jqka.com.cn/v6/quote/sz_{stock['code']}.js\"\n        elif stock['market'] == 'bj':\n            url = f\"https://d.10jqka.com.cn/v6/quote/bj_{stock['code']}.js\"\n        \n        headers = {\n            'User-Agent': 'Mozilla/5.0',\n            'Referer': 'https://q.10jqka.com.cn/'\n        }\n        \n        response = requests.get(url, headers=headers, timeout=5)\n        content = response.text\n        \n        # 解析数据\n        match = re.search(r'\\{.*\\}', content)\n        if match:\n            data_str = match.group()\n            # 提取关键字段\n            price_match = re.search(r'\"now\":\"([^\"]+)\"', data_str)\n            open_match = re.search(r'\"open\":\"([^\"]+)\"', data_str)\n            high_match = re.search(r'\"high\":\"([^\"]+)\"', data_str)\n            low_match = re.search(r'\"low\":\"([^\"]+)\"', data_str)\n            preclose_match = re.search(r'\"yclose\":\"([^\"]+)\"', data_str)\n            volume_match = re.search(r'\"volume\":\"([^\"]+)\"', data_str)\n            amount_match = re.search(r'\"turnover\":\"([^\"]+)\"', data_str)\n            \n            if price_match:\n                now = float(price_match.group(1))\n                open_p = float(open_match.group(1)) if open_match else 0\n                high = float(high_match.group(1)) if high_match else 0\n                low = float(low_match.group(1)) if low_match else 0\n                preclose = float(preclose_match.group(1)) if preclose_match else 0\n                change = now - preclose\n                pct_change = (change / preclose * 100) if preclose else 0\n                \n                results.append({\n                    'code': stock['code'],\n                    'name': stock['name'],\n                    'price': now,\n                    'change': change,\n                    'pct_change': pct_change,\n                    'open': open_p,\n                    'high': high,\n                    'low': low,\n                    'volume': volume_match.group(1) if volume_match else 'N/A',\n                    'amount': amount_match.group(1) if amount_match else 'N/A'\n                })\n    except Exception as e:\n        pass\n\n# 按涨跌幅排序\nresults.sort(key=lambda x: x['pct_change'], reverse=True)\n\n# 输出结果\nprint(f\"{'代码':<10} {'名称':<10} {'现价':>8} {'涨跌%':>10} {'涨跌额':>10} {'今开':>8} {'最高':>8} {'最低':>8}\")\nprint(\"-\" * 85)\nfor r in results:\n    symbol = \"🔺\" if r['pct_change'] > 0 else (\"🔻\" if r['pct_change'] < 0 else \"➖\")\n    print(f\"{r['code']:<10} {r['name']:<10} {r['price']:>8.2f} {symbol}{r['pct_change']:>9.2f}% {r['change']:>+10.2f} {r['open']:>8.2f} {r['high']:>8.2f} {r['low']:>8.2f}\")\n\nprint()\nprint(f\"数据来源：同花顺实时行情\")\nEOF\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773108158403}}
