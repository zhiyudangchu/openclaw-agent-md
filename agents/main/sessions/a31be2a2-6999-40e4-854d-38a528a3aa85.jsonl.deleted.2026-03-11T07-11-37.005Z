{"type":"message","id":"e50572f0","parentId":"5224ebe8","timestamp":"2026-03-10T02:09:59.428Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to create a Python script to fetch real-time stock data for all stocks in the watchlist using tushare's rt_min interface, format the data according to the template requirements.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_f2d2c05ea39949aebede358b","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace-main-stock/stock/fetch_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n获取自选股实时数据\n\"\"\"\n\nimport tushare as ts\nfrom datetime import datetime\nimport pandas as pd\n\n# Tushare Pro API\npro = ts.pro_api('d5dffac476638f230dbe209bef04cd97b100c2dd3ddd10ddf85bc33d')\n\n# 读取自选股列表\nwatchlist_path = '/home/openclaw/.openclaw/workspace-main-stock/stock/watchlist.txt'\nstocks = []\nwith open(watchlist_path, 'r', encoding='utf-8') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            code, name = line.split('|')\n            stocks.append({'code': code, 'name': name})\n\n# 存储结果\nresults = []\n\n# 获取实时数据\nfor stock in stocks:\n    code = stock['code']\n    name = stock['name']\n    \n    try:\n        # 处理港股和美股\n        if '.HK' in code:\n            ts_code = code  # 港股保持原样\n        elif code.isdigit() and len(code) == 6:\n            # A 股，添加后缀\n            if code.startswith('6') or code.startswith('001'):\n                ts_code = f\"{code}.SH\"\n            else:\n                ts_code = f\"{code}.SZ\"\n        else:\n            # 美股或其他\n            ts_code = code\n        \n        # 获取实时分钟数据\n        df = pro.rt_min(ts_code=ts_code, freq='1MIN')\n        \n        if df is not None and len(df) > 0:\n            # 获取最新一条数据\n            latest = df.iloc[0]\n            \n            # 计算涨跌幅和涨跌额\n            pre_close = latest.get('pre_close', 0)\n            close = latest.get('close', 0)\n            \n            if pre_close > 0 and close > 0:\n                change_pct = ((close - pre_close) / pre_close) * 100\n                change_amt = close - pre_close\n                \n                # 获取时间\n                trade_time = latest.get('trade_time', '')\n                if trade_time:\n                    # 转换时间格式\n                    try:\n                        dt = datetime.strptime(trade_time, '%Y%m%d%H%M%S')\n                        time_str = dt.strftime('%Y-%m-%d %H:%M:%S')\n                    except:\n                        time_str = trade_time\n                else:\n                    time_str = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                \n                results.append({\n                    'code': code,\n                    'name': name,\n                    'price': close,\n                    'change_pct': change_pct,\n                    'change_amt': change_amt,\n                    'time': time_str,\n                    'pre_close': pre_close\n                })\n    except Exception as e:\n        print(f\"获取 {code} 失败：{str(e)}\")\n        continue\n\n# 输出结果\nif results:\n    df_result = pd.DataFrame(results)\n    print(df_result.to_string(index=False))\nelse:\n    print(\"未获取到任何数据\")\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773108589863}}
