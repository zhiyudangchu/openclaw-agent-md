{"type":"message","id":"f6de0c2e","parentId":"8f7ba0b5","timestamp":"2026-03-10T02:10:41.216Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Sina API failed, so I'll try using Tushare's real-time quote interface (pro.quote) which might work better for A-shares.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_ee9d5f8f75f24fb9a9312aee","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace-main-stock/stock/fetch_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n获取自选股实时数据 - 使用 Tushare 实时行情接口\n\"\"\"\n\nimport tushare as ts\nfrom datetime import datetime\nimport pandas as pd\n\n# Tushare Pro API\npro = ts.pro_api('d5dffac476638f230dbe209bef04cd97b100c2dd3ddd10ddf85bc33d')\n\n# 读取自选股列表\nwatchlist_path = '/home/openclaw/.openclaw/workspace-main-stock/stock/watchlist.txt'\nstocks = []\nwith open(watchlist_path, 'r', encoding='utf-8') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            code, name = line.split('|')\n            # 只处理 A 股\n            if code.isdigit() and len(code) == 6:\n                if code.startswith('6') or code.startswith('001') or code.startswith('688'):\n                    ts_code = f\"{code}.SH\"\n                else:\n                    ts_code = f\"{code}.SZ\"\n                stocks.append({'code': code, 'name': name, 'ts_code': ts_code})\n\n# 存储结果\nresults = []\n\n# 获取实时行情\ntry:\n    # 获取所有股票的 ts_code 列表\n    ts_codes = [s['ts_code'] for s in stocks]\n    \n    # 使用实时行情接口\n    df = pro.quote(ts_code=','.join(ts_codes))\n    \n    if df is not None and len(df) > 0:\n        for _, row in df.iterrows():\n            ts_code = row.get('ts_code', '')\n            \n            # 找到对应的股票信息\n            stock_info = next((s for s in stocks if s['ts_code'] == ts_code), None)\n            if not stock_info:\n                continue\n            \n            code = stock_info['code']\n            name = stock_info['name']\n            \n            # 提取数据\n            current_price = row.get('price', 0)\n            pre_close = row.get('pre_close', 0)\n            change_pct = row.get('pct_chg', 0)\n            \n            if pre_close > 0 and current_price > 0:\n                change_amt = current_price - pre_close\n                \n                # 时间\n                time_str = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                \n                results.append({\n                    'code': code,\n                    'name': name,\n                    'price': current_price,\n                    'change_pct': change_pct,\n                    'change_amt': change_amt,\n                    'time': time_str,\n                    'pre_close': pre_close\n                })\n                \n                print(f\"✓ {code} {name}: ¥{current_price:.2f} ({change_pct:+.2f}%)\")\n    else:\n        print(\"未获取到数据\")\n        \nexcept Exception as e:\n    print(f\"获取数据失败：{str(e)}\")\n    \n    # 备用方案：逐个获取\n    print(\"\\n尝试逐个获取...\")\n    for stock in stocks:\n        try:\n            df = pro.quote(ts_code=stock['ts_code'])\n            if df is not None and len(df) > 0:\n                row = df.iloc[0]\n                current_price = row.get('price', 0)\n                pre_close = row.get('pre_close', 0)\n                change_pct = row.get('pct_chg', 0)\n                \n                if pre_close > 0 and current_price > 0:\n                    change_amt = current_price - pre_close\n                    time_str = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                    \n                    results.append({\n                        'code': stock['code'],\n                        'name': stock['name'],\n                        'price': current_price,\n                        'change_pct': change_pct,\n                        'change_amt': change_amt,\n                        'time': time_str,\n                        'pre_close': pre_close\n                    })\n                    print(f\"✓ {stock['code']} {stock['name']}: ¥{current_price:.2f} ({change_pct:+.2f}%)\")\n        except Exception as e2:\n            print(f\"✗ {stock['code']} {stock['name']}: {str(e2)}\")\n\n# 输出结果\nprint(f\"\\n=== 成功获取 {len(results)}/{len(stocks)} 只股票数据 ===\")\n\n# 保存结果\nif results:\n    df_result = pd.DataFrame(results)\n    output_path = '/home/openclaw/.openclaw/workspace-main-stock/stock/realtime-data.txt'\n    df_result.to_csv(output_path, index=False, encoding='utf-8')\n    print(f\"\\n数据已保存到：{output_path}\")\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773108627623}}
