{"type":"message","id":"99ab1894","parentId":"a1a41b1c","timestamp":"2026-03-10T02:10:22.366Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Tushare 的 rt_min 接口不支持港股和美股，需要改用同花顺网页接口获取实时数据。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_503e428ff8ff444993d0cf33","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace-main-stock/stock/fetch_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n获取自选股实时数据 - 使用同花顺网页接口\n\"\"\"\n\nimport requests\nimport re\nfrom datetime import datetime\nimport json\n\n# 读取自选股列表\nwatchlist_path = '/home/openclaw/.openclaw/workspace-main-stock/stock/watchlist.txt'\nstocks = []\nwith open(watchlist_path, 'r', encoding='utf-8') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            code, name = line.split('|')\n            stocks.append({'code': code, 'name': name})\n\n# 存储结果\nresults = []\n\n# 同花顺实时数据接口\ndef get_stock_data(code, name):\n    \"\"\"从同花顺获取实时数据\"\"\"\n    try:\n        # 处理不同市场的股票代码\n        if '.HK' in code:\n            # 港股\n            url = f\"http://hq.sinajs.cn/rn={int(datetime.now().timestamp()*1000)}&list=rt_hk{code.replace('.HK', '')}\"\n        elif code.isdigit() and len(code) == 6:\n            # A 股\n            if code.startswith('6') or code.startswith('001'):\n                url = f\"http://hq.sinajs.cn/rn={int(datetime.now().timestamp()*1000)}&list=s_sh{code}\"\n            else:\n                url = f\"http://hq.sinajs.cn/rn={int(datetime.now().timestamp()*1000)}&list=s_sz{code}\"\n        else:\n            return None\n        \n        headers = {\n            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n            'Referer': 'http://quote.eastmoney.com/'\n        }\n        \n        response = requests.get(url, headers=headers, timeout=5)\n        response.encoding = 'gbk'\n        \n        if response.status_code == 200:\n            content = response.text.strip()\n            \n            # 解析数据\n            if '=' in content:\n                data_part = content.split('=', 1)[1].strip('\"').strip(\"'\")\n                parts = data_part.split(',')\n                \n                if len(parts) >= 4:\n                    # 提取关键数据\n                    if '.HK' in code:\n                        # 港股格式\n                        current_price = float(parts[1]) if parts[1] else 0\n                        pre_close = float(parts[2]) if parts[2] else 0\n                        open_price = float(parts[3]) if parts[3] else 0\n                        high = float(parts[4]) if parts[4] else 0\n                        low = float(parts[5]) if parts[5] else 0\n                        volume = float(parts[10]) if len(parts) > 10 and parts[10] else 0\n                        time_str = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                    else:\n                        # A 股格式\n                        open_price = float(parts[1]) if parts[1] else 0\n                        pre_close = float(parts[2]) if parts[2] else 0\n                        current_price = float(parts[3]) if parts[3] else 0\n                        high = float(parts[4]) if parts[4] else 0\n                        low = float(parts[5]) if parts[5] else 0\n                        volume = float(parts[8]) if len(parts) > 8 and parts[8] else 0\n                        time_str = parts[30] if len(parts) > 30 and parts[30] else datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                    \n                    # 计算涨跌幅\n                    if pre_close > 0 and current_price > 0:\n                        change_pct = ((current_price - pre_close) / pre_close) * 100\n                        change_amt = current_price - pre_close\n                        \n                        return {\n                            'code': code,\n                            'name': name,\n                            'price': current_price,\n                            'change_pct': change_pct,\n                            'change_amt': change_amt,\n                            'time': time_str,\n                            'pre_close': pre_close,\n                            'open': open_price,\n                            'high': high,\n                            'low': low,\n                            'volume': volume\n                        }\n    except Exception as e:\n        print(f\"获取 {code} 失败：{str(e)}\")\n    \n    return None\n\n# 获取所有股票数据\nprint(\"正在获取实时数据...\")\nfor stock in stocks:\n    code = stock['code']\n    name = stock['name']\n    \n    data = get_stock_data(code, name)\n    if data:\n        results.append(data)\n        print(f\"✓ {code} {name}: ¥{data['price']:.2f} ({data['change_pct']:+.2f}%)\")\n    else:\n        print(f\"✗ {code} {name}: 获取失败\")\n\n# 输出结果\nprint(f\"\\n=== 成功获取 {len(results)}/{len(stocks)} 只股票数据 ===\")\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773108608779}}
