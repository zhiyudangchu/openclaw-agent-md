7.shtml?type=1&source=pc_guanwangzuoce\n      - listitem [ref=e1112]:\n        - link \"手机版\" [ref=e1113] [cursor=pointer]:\n          - /url: //mobile.10jqka.com.cn/\n    - link \"x\" [ref=e1114] [cursor=pointer]:\n      - /url: \"#\"\n<<<END_EXTERNAL_UNTRUSTED_CONTENT id=\"b75d16d4c746eb74\">>>"}],"details":{"ok":true,"format":"ai","targetId":"DCCE598C540BE1A40A6027CB3010B265","url":"https://stockpage.10jqka.com.cn/601857/","refs":940,"externalContent":{"untrusted":true,"source":"browser","kind":"snapshot","format":"ai","wrapped":true}},"isError":false,"timestamp":1773108675141}}
{"type":"message","id":"07966a9e","parentId":"02459cca","timestamp":"2026-03-10T02:11:40.967Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"从网页快照中成功获取了中国石油的实时数据，现在需要创建一个完整的脚本来批量获取所有 A 股自选股的实时数据并保存到文件中。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"I can see the data from 同花顺 website. Let me create a Python script to fetch real-time data for all stocks in the watchlist using web scraping approach since Tushare APIs are not working properly.\n\n"},{"type":"toolCall","id":"call_ba8b17ed5ee64449a9c32a62","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace-main-stock/stock/fetch_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n获取自选股实时数据 - 使用同花顺网页接口\n\"\"\"\n\nimport requests\nimport re\nfrom datetime import datetime\n\n# 读取自选股列表\nwatchlist_path = '/home/openclaw/.openclaw/workspace-main-stock/stock/watchlist.txt'\nstocks = []\nwith open(watchlist_path, 'r', encoding='utf-8') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            code, name = line.split('|')\n            # 只处理 A 股\n            if code.isdigit() and len(code) == 6:\n                stocks.append({'code': code, 'name': name})\n\n# 存储结果\nresults = []\n\ndef get_stock_data_10jqka(code, name):\n    \"\"\"从同花顺获取实时数据\"\"\"\n    try:\n        url = f\"http://stockpage.10jqka.com.cn/{code}/\"\n        headers = {\n            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',\n            'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,image/webp,*/*;q=0.8',\n            'Accept-Language': 'zh-CN,zh;q=0.9,en;q=0.8',\n        }\n        \n        response = requests.get(url, headers=headers, timeout=10)\n        response.encoding = 'utf-8'\n        \n        if response.status_code == 200:\n            content = response.text\n            \n            # 使用正则表达式提取数据\n            # 查找现价\n            price_match = re.search(r'\"(?:现价 | 最新价).*?[\"\\s:]*(\\d+\\.\\d+)', content)\n            if not price_match:\n                # 尝试另一种模式\n                price_match = re.search(r'[\"\\']?现价 [\"\\']?\\s*[:\\s]*[\"\\']?(\\d+\\.\\d+)[\"\\']?', content)\n            \n            # 查找涨跌幅\n            pct_match = re.search(r'[-]?\\d+\\.\\d+%', content)\n            \n            # 查找涨跌额\n            change_match = re.search(r'[-]?\\d+\\.\\d+(?=\\s*[-+]?\\d+\\.\\d+%)', content)\n            \n            if price_match:\n                price = float(price_match.group(1))\n                pct_chg = float(pct_match.group(0).replace('%', '')) if pct_match else 0\n                change_amt = float(change_match.group(0)) if change_match else 0\n                \n                return {\n                    'code': code,\n                    'name': name,\n                    'price': price,\n                    'change_pct': pct_chg,\n                    'change_amt': change_amt,\n                    'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                }\n    except Exception as e:\n        print(f\"获取 {code} 失败：{str(e)}\")\n    \n    return None\n\n# 获取所有股票数据\nprint(\"正在获取实时数据...\")\nfor stock in stocks:\n    code = stock['code']\n    name = stock['name']\n    \n    data = get_stock_data_10jqka(code, name)\n    if data:\n        results.append(data)\n        print(f\"✓ {code} {name}: ¥{data['price']:.2f} ({data['change_pct']:+.2f}%)\")\n    else:\n        print(f\"✗ {code} {name}: 获取失败\")\n\n# 输出结果\nprint(f\"\\n=== 成功获取 {len(results)}/{len(stocks)} 只股票数据 ===\")\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773108675143}}
