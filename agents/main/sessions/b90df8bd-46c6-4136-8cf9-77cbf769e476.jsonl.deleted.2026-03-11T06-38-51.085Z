{"type":"message","id":"2ca2ba7b","parentId":"8b831473","timestamp":"2026-03-10T06:35:53.831Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"环境变量中的 token 已确认存在，需要修改脚本直接读取并打印 token 来调试问题，同时添加更详细的错误处理。","thinkingSignature":"reasoning_content"},{"type":"text","text":"Token 存在。让我修改脚本，直接使用 token 并添加调试信息：\n\n"},{"type":"toolCall","id":"call_cb5b084d488843c59f7845dd","name":"write","arguments":{"content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n检查今日是否休市，并获取自选股实时日线数据\n\"\"\"\nimport os\nimport sys\nimport tushare as ts\nfrom datetime import datetime\n\n# 初始化 pro 接口\ntoken = os.getenv('TUSHARE_TOKEN')\nprint(f\"Token: {token[:10]}...{token[-10:] if len(token) > 20 else token}\")\n\nif not token:\n    print(\"ERROR: TUSHARE_TOKEN 环境变量未设置\")\n    sys.exit(1)\n\npro = ts.pro_api(token)\n\n# 获取今天日期\ntoday = datetime.now().strftime('%Y%m%d')\ntoday_str = datetime.now().strftime('%Y-%m-%d')\n\n# 检查交易日历（上交所）\ntry:\n    print(f\"检查交易日历：{today}\")\n    cal_df = pro.trade_cal(exchange='SSE', start_date=today, end_date=today, is_open='1')\n    print(f\"交易日历返回：{cal_df}\")\n    if cal_df.empty:\n        print(f\"今日 ({today_str}) 休市，结束任务\")\n        sys.exit(0)\n    else:\n        print(f\"今日 ({today_str}) 正常交易，继续执行\")\nexcept Exception as e:\n    print(f\"检查交易日历出错：{e}\")\n    import traceback\n    traceback.print_exc()\n    sys.exit(1)\n\n# 读取自选股列表\nwatchlist_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/watchlist.txt')\nstocks = []\ntry:\n    with open(watchlist_path, 'r', encoding='utf-8') as f:\n        for line in f:\n            line = line.strip()\n            if line and '|' in line:\n                code, name = line.split('|', 1)\n                # 转换代码格式为 tushare 格式\n                if '.' not in code:\n                    if code.startswith('6') or code.startswith('9'):\n                        code = code + '.SH'\n                    else:\n                        code = code + '.SZ'\n                stocks.append(code)\nexcept Exception as e:\n    print(f\"读取自选股列表出错：{e}\")\n    sys.exit(1)\n\nif not stocks:\n    print(\"自选股列表为空\")\n    sys.exit(1)\n\nprint(f\"自选股数量：{len(stocks)}\")\nprint(f\"股票列表：{stocks}\")\n\n# 获取实时日线数据\ntry:\n    # 使用实时日线接口，一次性获取所有股票数据\n    ts_codes = ','.join(stocks)\n    print(f\"请求 tushare 实时日线数据：{ts_codes}\")\n    \n    # 使用实时日线接口 (doc_id=372)\n    df = pro.realtime_daily(ts_code=ts_codes)\n    \n    if df.empty:\n        print(\"未获取到实时数据\")\n        sys.exit(1)\n    \n    print(f\"获取到 {len(df)} 条数据\")\n    print(f\"列名：{df.columns.tolist()}\")\n    print(df)\n    \n    # 保存到 realtime-data.txt\n    output_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/realtime-data.txt')\n    df.to_csv(output_path, index=False, encoding='utf-8')\n    print(f\"数据已保存到：{output_path}\")\n    \nexcept Exception as e:\n    print(f\"获取实时数据出错：{e}\")\n    import traceback\n    traceback.print_exc()\n    sys.exit(1)\n","path":"~/.openclaw/workspace-main-stock/stock/check_market_status.py"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773124539036}}
