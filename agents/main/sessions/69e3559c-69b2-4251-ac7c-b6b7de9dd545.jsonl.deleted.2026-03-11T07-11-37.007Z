{"type":"message","id":"4d694ace","parentId":"9c53ddde","timestamp":"2026-03-10T06:55:59.605Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"文件已清空，现在需要创建 Python 脚本使用 Tushare 获取自选股的实时日线数据。","thinkingSignature":"reasoning_content"},{"type":"text","text":"现在我需要创建一个 Python 脚本来获取实时数据。根据 tushare-data skill 的说明，我需要使用实时日线接口：\n\n"},{"type":"toolCall","id":"call_f9357d76f2df47158d5c94a9","name":"write","arguments":{"path":"~/.openclaw/workspace-main-stock/stock/get_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n获取自选股实时日线数据\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nimport os\nfrom datetime import datetime\n\n# 读取环境变量中的 token\ntoken = os.getenv('TUSHARE_TOKEN')\n\nif not token:\n    print(\"错误：未设置 TUSHARE_TOKEN 环境变量\")\n    exit(1)\n\n# 初始化 pro 接口\npro = ts.pro_api(token)\n\n# 读取自选股列表\nwatchlist_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/watchlist.txt')\nstocks = []\nwith open(watchlist_path, 'r', encoding='utf-8') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            code, name = line.split('|', 1)\n            stocks.append((code, name))\n\nprint(f\"共读取 {len(stocks)} 只自选股\")\n\n# 获取实时日线数据\nresults = []\ntoday = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n\nfor code, name in stocks:\n    try:\n        # 处理不同市场的代码格式\n        ts_code = code\n        if code.endswith('.HK'):\n            # 港股\n            ts_code = code.replace('.HK', '.HK')\n        elif code.isdigit() and len(code) == 6:\n            # A 股，需要添加后缀\n            if code.startswith('6') or code.startswith('9'):\n                ts_code = code + '.SH'\n            else:\n                ts_code = code + '.SZ'\n        \n        # 获取实时日线数据\n        df = pro.daily(ts_code=ts_code, start_date=datetime.now().strftime('%Y%m%d'), end_date=datetime.now().strftime('%Y%m%d'))\n        \n        if df is not None and len(df) > 0:\n            row = df.iloc[0]\n            # 计算涨跌额和涨跌幅\n            close = row['close']\n            pre_close = row['pre_close']\n            change = close - pre_close\n            pct_change = (change / pre_close) * 100 if pre_close > 0 else 0\n            \n            results.append({\n                '代码': code,\n                '名称': name,\n                '当前价': close,\n                '涨跌额': change,\n                '涨跌幅': pct_change,\n                '昨收': pre_close,\n                '今开': row['open'],\n                '最高': row['high'],\n                '最低': row['low'],\n                '成交量': row['vol'],\n                '成交额': row['amount'],\n                '时间': today\n            })\n            print(f\"{code} {name}: {close:.2f} ({pct_change:+.2f}%)\")\n        else:\n            print(f\"{code} {name}: 无数据\")\n    except Exception as e:\n        print(f\"{code} {name}: 获取失败 - {e}\")\n\n# 保存结果\nif results:\n    df_result = pd.DataFrame(results)\n    output_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/realtime-data.txt')\n    df_result.to_csv(output_path, index=False, encoding='utf-8-sig')\n    print(f\"\\n数据已保存至 {output_path}\")\n    print(f\"共获取 {len(results)} 条记录\")\nelse:\n    print(\"\\n未获取到任何数据\")\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773125749949}}
