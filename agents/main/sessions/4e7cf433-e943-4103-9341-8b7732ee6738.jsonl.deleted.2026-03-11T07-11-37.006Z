984.0,\n        \"f140\": -247944128.0,"}],"details":{"status":"completed","exitCode":0,"durationMs":79,"aggregated":"{\n    \"rc\": 0,\n    \"rt\": 4,\n    \"svr\": 175646286,\n    \"lt\": 1,\n    \"full\": 1,\n    \"dlmkts\": \"\",\n    \"data\": {\n        \"f43\": 1194,\n        \"f44\": 1230,\n        \"f45\": 1178,\n        \"f46\": 1218,\n        \"f103\": 417473000000.0,\n        \"f104\": 2849543000000.0,\n        \"f105\": 126279000000.0,\n        \"f106\": 100,\n        \"f107\": 1,\n        \"f108\": 0.864223336,\n        \"f109\": 164676000000.0,\n        \"f110\": 1,\n        \"f111\": 2,\n        \"f112\": \"2\",\n        \"f113\": 0,\n        \"f114\": 0,\n        \"f115\": 0,\n        \"f116\": 2185270475146.92,\n        \"f117\": 1933349609146.92,\n        \"f118\": 2,\n        \"f119\": -920,\n        \"f120\": 1180,\n        \"f121\": 1928,\n        \"f122\": 1470,\n        \"f123\": 0,\n        \"f124\": 0,\n        \"f125\": 0,\n        \"f126\": 3.94,\n        \"f127\": \"\\u70bc\\u5316\\u53ca\\u8d38\\u6613\",\n        \"f128\": \"\\u5317\\u4eac\\u677f\\u5757\",\n        \"f129\": \"AH\\u80a1,HS300_,\\u4e2d\\u5b57\\u5934,\\u673a\\u6784\\u91cd\\u4ed3,\\u878d\\u8d44\\u878d\\u5238,\\u9875\\u5ca9\\u6c14,\\u53c2\\u80a1\\u4fdd\\u9669,\\u4e0a\\u8bc150_,\\u4e0a\\u8bc1180_,\\u592e\\u56fd\\u4f01\\u6539\\u9769,\\u6caa\\u80a1\\u901a,\\u4e00\\u5e26\\u4e00\\u8def,\\u8bc1\\u91d1\\u6301\\u80a1,MSCI\\u4e2d\\u56fd,\\u5929\\u7136\\u6c14,\\u6807\\u51c6\\u666e\\u5c14,\\u4e2d\\u7279\\u4f30,\\u4e1c\\u65b9\\u8d22\\u5bcc\\u70ed\\u80a1,\\u5468\\u671f\\u80a1,\\u4ef7\\u503c\\u80a1,\\u7ea2\\u5229\\u80a1\",\n        \"f130\": 0,\n        \"f131\": 0,\n        \"f132\": 0,\n        \"f133\": 0,\n        \"f134\": 0,\n        \"f135\": 2433347008.0,\n        \"f136\": 2771470608.0,\n        \"f137\": -338123600.0,\n        \"f138\": 951147856.0,\n        \"f139\": 1199091984.0,\n        \"f140\": -247944128.0,","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"tim