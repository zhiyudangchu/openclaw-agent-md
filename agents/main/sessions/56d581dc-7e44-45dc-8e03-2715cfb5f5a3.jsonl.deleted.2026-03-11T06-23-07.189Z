{"type":"message","id":"40d8d18f","parentId":"50c6c775","timestamp":"2026-03-10T06:21:54.653Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"数据获取成功，现在需要按照预警规则过滤数据并保存到 realtime-data.txt 文件中。","thinkingSignature":"reasoning_content"},{"type":"text","text":"数据看起来合理了。现在让我按照 alert-rules.md 的预警规则过滤数据，并保存到 realtime-data.txt：\n\n预警规则：\n- 通用：下跌 > 3% 或 上涨 > 5%\n- 中国石油 (601857.SH) 专属：涨幅 > 2% 或 跌幅 > 1%\n\n"},{"type":"toolCall","id":"call_44e6bcf3d2d94cd0bce9358b","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace-main-stock && python3 << 'EOF'\nimport requests\nfrom datetime import datetime\n\n# 读取 watchlist\nwith open('stock/watchlist.txt', 'r', encoding='utf-8') as f:\n    lines = f.readlines()\n\nstocks = []\nfor line in lines:\n    line = line.strip()\n    if line and '|' in line:\n        code, name = line.split('|')\n        stocks.append((code, name))\n\n# 预警规则\ndef check_alert(code, name, change_percent):\n    \"\"\"检查是否触发预警\"\"\"\n    if change_percent is None:\n        return False\n    \n    # 中国石油专属规则\n    if code == '601857':\n        if change_percent > 2:  # 涨幅 > 2%\n            return True\n        if change_percent < -1:  # 跌幅 > 1%\n            return True\n        return False\n    \n    # 通用规则\n    if change_percent < -3:  # 下跌 > 3%\n        return True\n    if change_percent > 5:  # 上涨 > 5%\n        return True\n    \n    return False\n\n# 获取数据并过滤\nresults = []\nfor code, name in stocks:\n    try:\n        if code.endswith('.HK'):\n            secid = f\"116.{code.replace('.HK', '')}\"\n        elif code.startswith('6') or code.startswith('9'):\n            secid = f\"1.{code}\"\n        elif code.startswith('0') or code.startswith('3'):\n            secid = f\"0.{code}\"\n        else:\n            continue\n        \n        url = f\"http://push2.eastmoney.com/api/qt/stock/get?secid={secid}&fields=f43,f44,f170\"\n        resp = requests.get(url, timeout=5)\n        data = resp.json()\n        \n        if data.get('data'):\n            d = data['data']\n            price = d.get('f43', 0) / 100 if d.get('f43') else 0\n            change_percent = d.get('f170', 0) / 100 if d.get('f170') else 0\n            change = d.get('f44', 0) / 100 if d.get('f44') else 0\n            \n            if check_alert(code, name, change_percent):\n                results.append({\n                    'code': code,\n                    'name': name,\n                    'price': price,\n                    'change_percent': change_percent,\n                    'change': change,\n                    'time': datetime.now().strftime('%H:%M:%S')\n                })\n    except:\n        pass\n\n# 按涨跌幅排序\nresults.sort(key=lambda x: abs(x['change_percent']), reverse=True)\n\n# 保存到文件\nwith open('stock/realtime-data.txt', 'w', encoding='utf-8') as f:\n    f.write(\"代码 | 名称 | 当前价 | 涨跌幅 | 涨跌额 | 时间\\n\")\n    for r in results:\n        sign = '+' if r['change_percent'] > 0 else ''\n        f.write(f\"{r['code']} | {r['name']} | ¥{r['price']:.2f} | {sign}{r['change_percent']:.2f}% | ¥{r['change']:.2f} | {r['time']}\\n\")\n\nprint(f\"共发现 {len(results)} 只股票触发预警\")\nfor r in results:\n    sign = '+' if r['change_percent'] > 0 else ''\n    print(f\"{r['code']} {r['name']}: ¥{r['price']:.2f} ({sign}{r['change_percent']:.2f}%)\")\nEOF"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773123705422}}
