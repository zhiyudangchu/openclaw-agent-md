lse 0\n            change = d.get('f44', 0) / 100 if d.get('f44') else 0\n            \n            results.append({\n                'code': code,\n                'name': name,\n                'price': f\"¥{price:.2f}\" if price else 'N/A',\n                'change_percent': f\"{change_percent:+.2f}%\" if change_percent != 0 else '0.00%',\n                'change': f\"¥{change:.2f}\" if change else 'N/A',\n                'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n                'change_percent_num': change_percent\n            })\n        else:\n            results.append({\n                'code': code,\n                'name': name,\n                'price': 'N/A',\n                'change_percent': 'N/A',\n                'change': 'N/A',\n                'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n                'change_percent_num': 0\n            })\n    except Exception as e:\n        results.append({\n            'code': code,\n            'name': name,\n            'price': 'N/A',\n            'change_percent': 'N/A',\n            'change': 'N/A',\n            'time': datetime.now().strftime('%Y-%m-%d %H:%M:%S'),\n            'change_percent_num': 0\n        })\n\n# 输出结果\nprint(\"代码 | 名称 | 当前价 | 涨跌幅 | 涨跌额 | 时间\")\nfor r in results:\n    print(f\"{r['code']} | {r['name']} | {r['price']} | {r['change_percent']} | {r['change']} | {r['time']}\")\nEOF"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773123692612}}
