{"type":"message","id":"0b3c6f63","parentId":"a1cad418","timestamp":"2026-03-10T03:03:13.936Z","message":{"role":"toolResult","toolCallId":"call_8502dd6a1b9f4b779dc08d8e","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n股票数据获取示例脚本\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nimport os\n\n# 读取环境变量中的token, 或者读取本地记录的token\ntoken = os.getenv('TUSHARE_TOKEN') or ts.get_token()\n\n# 初始化pro接口\npro = ts.pro_api(token)\n\n\ndef get_stock_list():\n    \"\"\"\n    获取股票列表\n    \"\"\"\n    try:\n        data = pro.stock_basic(exchange='', list_status='L', fields='ts_code,symbol,name,area,industry,list_date')\n        print(\"股票列表获取成功：\")\n        print(data.head())\n        return data\n    except Exception as e:\n        print(f\"获取股票列表失败：{e}\")\n        return None\n\n\ndef get_daily_data(ts_code, start_date, end_date):\n    \"\"\"\n    获取股票日线数据\n    \"\"\"\n    try:\n        data = pro.daily(ts_code=ts_code, start_date=start_date, end_date=end_date)\n        print(f\"{ts_code}日线数据获取成功：\")\n        print(data.head())\n        return data\n    except Exception as e:\n        print(f\"获取日线数据失败：{e}\")\n        return None\n\n\ndef get_financial_data(ts_code, year, quarter):\n    \"\"\"\n    获取财务指标数据\n    \"\"\"\n    try:\n        data = pro.fina_indicator(ts_code=ts_code, year=year, quarter=quarter)\n        print(f\"{ts_code}财务指标数据获取成功：\")\n        print(data.head())\n        return data\n    except Exception as e:\n        print(f\"获取财务指标数据失败：{e}\")\n        return None\n\n\ndef main():\n    \"\"\"\n    主函数\n    \"\"\"\n    print(\"===== tushare 股票数据获取示例 =====\")\n    \n    # 获取股票列表\n    stock_list = get_stock_list()\n    \n    if stock_list is not None:\n        # 获取第一只股票的代码\n        ts_code = stock_list['ts_code'].iloc[0]\n        print(f\"\\n使用股票代码：{ts_code}\")\n        \n        # 获取日线数据（最近30天）\n        import datetime\n        end_date = datetime.datetime.now().strftime('%Y%m%d')\n        start_date = (datetime.datetime.now() - datetime.timedelta(days=30)).strftime('%Y%m%d')\n        print(f\"\\n获取日线数据：{start_date} 至 {end_date}\")\n        get_daily_data(ts_code, start_date, end_date)\n        \n        # 获取财务数据（最近一年）\n        current_year = datetime.datetime.now().year\n        print(f\"\\n获取财务数据：{current_year-1}年 第4季度\")\n        get_financial_data(ts_code, current_year-1, 4)\n\n\nif __name__ == \"__main__\":\n    main()\n"}],"isError":false,"timestamp":1773111793935}}
{"type":"message","id":"536d03f9","parentId":"0b3c6f63","timestamp":"2026-03-10T03:04:29.215Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to create a script to fetch real-time stock data. According to the tushare documentation, I should use the \"实时日线\" (real-time daily) interface. Let me check the tushare documentation for real-time data.\n\nBased on the skill documentation, I should use:\n- 实时日线: https://tushare.pro/document/2?doc_id=109 (通用行情接口)\n\nLet me create a Python script to:\n1. Check if market is open today\n2. Get real-time data for all stocks in watchlist\n3. Apply alert rules\n4. Save to realtime-data.txt\n5. Send notifications if alerts triggered\n\nFirst, let me create the script.\n","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_f562800dd4344f9199ec28a5","name":"write","arguments":{"path":"~/.openclaw/workspace-main-stock/stock/get_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n实时股价数据获取脚本\n获取自选股实时数据并应用预警规则\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nimport os\nimport sys\nfrom datetime import datetime, timedelta\n\n# 读取环境变量中的token\ntoken = os.getenv('TUSHARE_TOKEN')\nif not token:\n    print(\"错误：未找到 TUSHARE_TOKEN 环境变量\")\n    sys.exit(1)\n\n# 初始化pro接口\npro = ts.pro_api(token)\n\ndef check_market_status():\n    \"\"\"\n    检查今日是否开盘且未收盘\n    返回：True=未收盘可获取实时数据，False=已收盘或休市\n    \"\"\"\n    today = datetime.now().strftime('%Y%m%d')\n    now = datetime.now()\n    \n    # 检查是否是交易日\n    try:\n        # 获取交易日历\n        cal = pro.trade_cal(exchange='SSE', start_date=today, end_date=today)\n        if cal.empty or cal['is_open'].iloc[0] == 0:\n            print(f\"今日 ({today}) 不是交易日\")\n            return False\n    except Exception as e:\n        print(f\"获取交易日历失败：{e}\")\n        # 如果是周末，直接返回False\n        if now.weekday() >= 5:\n            print(\"今天是周末，休市\")\n            return False\n    \n    # 检查时间：A股交易时间 9:30-11:30, 13:00-15:00\n    hour = now.hour\n    minute = now.minute\n    \n    # 下午3点后算收盘\n    if hour >= 15:\n        print(\"已收盘 (15:00 后)\")\n        return False\n    # 中午休市时间\n    if 11 <= hour < 13:\n        print(\"中午休市时间\")\n        return False\n    # 早上9:30前\n    if hour < 9 or (hour == 9 and minute < 30):\n        print(\"尚未开盘 (9:30 前)\")\n        return False\n    \n    print(\"市场交易中，可以获取实时数据\")\n    return True\n\ndef get_watchlist():\n    \"\"\"\n    读取自选股列表\n    返回：股票代码列表 (ts_code格式)\n    \"\"\"\n    watchlist_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/watchlist.txt')\n    stocks = []\n    \n    with open(watchlist_path, 'r', encoding='utf-8') as f:\n        for line in f:\n            line = line.strip()\n            if not line or line.startswith('#'):\n                continue\n            parts = line.split('|')\n            if len(parts) >= 1:\n                code = parts[0].strip()\n                name = parts[1].strip() if len(parts) > 1 else ''\n                \n                # 转换为ts_code格式\n                if '.' in code:\n                    # 已经是ts_code格式 (如 9866.HK)\n                    ts_code = code.upper()\n                elif code.startswith('6') or code.startswith('9') or code.startswith('5'):\n                    # 沪市\n                    ts_code = code + '.SH'\n                elif code.startswith('0') or code.startswith('3'):\n                    # 深市\n                    ts_code = code + '.SZ'\n                else:\n                    # 美股等\n                    ts_code = code.upper()\n                \n                stocks.append({'ts_code': ts_code, 'name': name, 'original_code': code})\n    \n    return stocks\n\ndef get_realtime_data(stocks):\n    \"\"\"\n    获取实时行情数据\n    使用通用行情接口获取实时数据\n    \"\"\"\n    ts_codes = [s['ts_code'] for s in stocks]\n    \n    # 分离A股和港股/美股\n    a_stocks = [c for c in ts_codes if c.endswith('.SH') or c.endswith('.SZ')]\n    hk_stocks = [c for c in ts_codes if c.endswith('.HK')]\n    us_stocks = [c for c in ts_codes if not (c.endswith('.SH') or c.endswith('.SZ') or c.endswith('.HK'))]\n    \n    all_data = []\n    \n    # 获取A股实时数据 - 使用实时日线接口\n    if a_stocks:\n        try:\n            # 批量获取，每次最多100只\n            for i in range(0, len(a_stocks), 100):\n                batch = a_stocks[i:i+100]\n                ts_code_str = ','.join(batch)\n                data = pro.realtime_daily(ts_code=ts_code_str)\n                if data is not None and not data.empty:\n                    for _, row in data.iterrows():\n                        all_data.append(row)\n                print(f\"A股数据获取成功：{len(batch)}只\")\n        except Exception as e:\n            print(f\"获取A股实时数据失败：{e}\")\n            # 尝试使用通用行情接口\n            try:\n                for i in range(0, len(a_stocks), 100):\n                    batch = a_stocks[i:i+100]\n                    ts_code_str = ','.join(batch)\n                    data = pro.query('daily', ts_code=ts_code_str, start_date=datetime.now().strftime('%Y%m%d'), end_date=datetime.now().strftime('%Y%m%d'))\n                    if data is not None and not data.empty:\n                        for _, row in data.iterrows():\n                            all_data.append(row)\n                print(f\"A股日线数据获取成功\")\n            except Exception as e2:\n                print(f\"获取A股日线数据也失败：{e2}\")\n    \n    # 获取港股实时数据\n    if hk_stocks:\n        try:\n            for i in range(0, len(hk_stocks), 100):\n                batch = hk_stocks[i:i+100]\n                ts_code_str = ','.join(batch)\n                data = pro.hk_daily(ts_code=ts_code_str, start_date=datetime.now().strftime('%Y%m%d'), end_date=datetime.now().strftime('%Y%m%d'))\n                if data is not None and not data.empty:\n                    for _, row in data.iterrows():\n                        all_data.append(row)\n                print(f\"港股数据获取成功：{len(batch)}只\")\n        except Exception as e:\n            print(f\"获取港股数据失败：{e}\")\n    \n    # 获取美股实时数据\n    if us_stocks:\n        try:\n            for code in us_stocks:\n                data = pro.us_daily(ts_code=code, start_date=datetime.now().strftime('%Y%m%d'), end_date=datetime.now().strftime('%Y%m%d'))\n                if data is not None and not data.empty:\n                    for _, row in data.iterrows():\n                        all_data.append(row)\n                print(f\"美股 {code} 数据获取成功\")\n        except Exception as e:\n            print(f\"获取美股数据失败：{e}\")\n    \n    return pd.DataFrame(all_data) if all_data else pd.DataFrame()\n\ndef format_realtime_data(df, stocks):\n    \"\"\"\n    格式化实时数据为所需格式\n    \"\"\"\n    if df.empty:\n        return []\n    \n    # 创建股票代码到名称的映射\n    code_to_name = {s['ts_code']: s['name'] for s in stocks}\n    \n    result = []\n    timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n    \n    for _, row in df.iterrows():\n        ts_code = row.get('ts_code', '')\n        \n        # 获取股票名称\n        name = code_to_name.get(ts_code, row.get('name', ''))\n        if not name:\n            name = row.get('name', '')\n        \n        # 获取价格数据\n        close = row.get('close', 0) or row.get('pre_close', 0)\n        pre_close = row.get('pre_close', 0)\n        pct_chg = row.get('pct_chg', 0)\n        \n        # 计算涨跌额\n        price_change = close - pre_close if pre_close > 0 else 0\n        \n        # 格式化涨跌幅\n        if pct_chg >= 0:\n            change_pct_str = f\"+{pct_chg:.2f}%\"\n        else:\n            change_pct_str = f\"{pct_chg:.2f}%\"\n        \n        result.append({\n            'code': ts_code.split('.')[0],\n            'name': name,\n            'price': close,\n            'change_pct': pct_chg,\n            'change_pct_str': change_pct_str,\n            'price_change': price_change,\n            'price_change_str': f\"¥{price_change:.2f}\",\n            'time': timestamp\n        })\n    \n    return result\n\ndef check_alert_rules(data):\n    \"\"\"\n    根据预警规则过滤数据\n    通用规则：\n    - 下跌 > 3% → 触发\n    - 上涨 > 5% → 触发\n    \n    个股专属规则：\n    中国石油 (601857.SH):\n    - 涨幅 > 2% → 触发\n    - 跌幅 > 1% → 触发\n    \"\"\"\n    alerts = []\n    \n    for item in data:\n        code = item['code']\n        change_pct = item['change_pct']\n        triggered = False\n        reason = \"\"\n        \n        # 检查是否是中国石油\n        if code == '601857':\n            # 中国石油专属规则\n            if change_pct > 2:\n                triggered = True\n                reason = \"🟢 涨幅 > 2%\"\n            elif change_pct < -1:\n                triggered = True\n                reason = \"🔴 跌幅 > 1%\"\n        else:\n            # 通用规则\n            if change_pct < -3:\n                triggered = True\n                reason = \"📉 下跌 > 3%\"\n            elif change_pct > 5:\n                triggered = True\n                reason = \"📈 上涨 > 5%\"\n        \n        if triggered:\n            item['alert_reason'] = reason\n            alerts.append(item)\n    \n    # 按涨跌幅排序\n    alerts.sort(key=lambda x: x['change_pct'], reverse=True)\n    \n    return alerts\n\ndef save_to_file(data, filepath):\n    \"\"\"\n    保存数据到文件\n    \"\"\"\n    with open(filepath, 'w', encoding='utf-8') as f:\n        f.write(\"代码 | 名称 | 现价 | 涨跌幅 | 涨跌额 | 时间\\n\")\n        for item in data:\n            line = f\"{item['code']}|{item['name']}|¥{item['price']:.2f}|{item['change_pct_str']}|{item['price_change_str']}|{item['time']}\\n\"\n            f.write(line)\n    \n    print(f\"数据已保存到 {filepath}\")\n\ndef format_alert_message(alerts):\n    \"\"\"\n    格式化预警消息\n    \"\"\"\n    if not alerts:\n        return \"\"\n    \n    # 构建表格形式的消息\n    lines = []\n    lines.append(\"⚠️ 股价预警通知\")\n    lines.append(f\"时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    lines.append(\"\")\n    lines.append(\"| 代码 | 名称 | 当前价 | 涨跌幅 | 涨跌额 | 时间 |\")\n    lines.append(\"|------|------|--------|--------|-------|------|\")\n    \n    for item in alerts:\n        time_short = item['time'].split(' ')[1][:5]  # HH:MM\n        line = f\"| {item['code']} | {item['name']} | ¥{item['price']:.2f} | {item['change_pct_str']} | {item['price_change_str']} | {time_short} |\"\n        lines.append(line)\n    \n    lines.append(\"\")\n    lines.append(\"⚙️ 预警规则\")\n    lines.append(\"• 📉 下跌 > 3% → 触发\")\n    lines.append(\"• 📈 上涨 > 5% → 触发\")\n    lines.append(\"• 中国石油：🟢 涨幅 > 2% / 🔴 跌幅 > 1%\")\n    \n    return \"\\n\".join(lines)\n\ndef main():\n    print(\"===== 实时股价监控 =====\")\n    print(f\"当前时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    \n    # 步骤1：检查市场状态\n    if not check_market_status():\n        print(\"市场已收盘或休市，结束本次任务\")\n        return\n    \n    # 步骤2：清空realtime-data.txt (已在cron配置中处理)\n    \n    # 步骤3：读取自选股列表\n    stocks = get_watchlist()\n    print(f\"自选股数量：{len(stocks)}\")\n    for s in stocks:\n        print(f\"  - {s['ts_code']} ({s['name']})\")\n    \n    # 步骤4：获取实时数据\n    print(\"\\n正在获取实时数据...\")\n    df = get_realtime_data(stocks)\n    \n    if df.empty:\n        print(\"未能获取到实时数据\")\n        return\n    \n    # 步骤5：格式化数据\n    formatted_data = format_realtime_data(df, stocks)\n    print(f\"\\n获取到 {len(formatted_data)} 只股票数据\")\n    \n    # 保存所有数据到文件\n    data_file = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/realtime-data.txt')\n    save_to_file(formatted_data, data_file)\n    \n    # 步骤6：应用预警规则\n    alerts = check_alert_rules(formatted_data)\n    print(f\"\\n触发预警的股票数量：{len(alerts)}\")\n    \n    if alerts:\n        print(\"\\n预警详情:\")\n        for a in alerts:\n            print(f\"  {a['code']} {a['name']}: {a['change_pct_str']} ({a['alert_reason']})\")\n        \n        # 步骤7：读取接收者列表\n        receiver_file = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/receiver-list.txt')\n        receivers = []\n        with open(receiver_file, 'r', encoding='utf-8') as f:\n            for line in f:\n                line = line.strip()\n                if line:\n                    receivers.append(line)\n        \n        print(f\"\\n接收者数量：{len(receivers)}\")\n        \n        # 步骤8：格式化预警消息\n        message = format_alert_message(alerts)\n        print(\"\\n预警消息:\")\n        print(message)\n        \n        # 输出推送命令\n        print(\"\\n===== 推送命令 =====\")\n        targets_args = ' '.join([f'--targets {r}' for r in receivers])\n        # 消息需要转义处理\n        escaped_message = message.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\n        cmd = f'openclaw message broadcast --channel feishu --account stock {targets_args} --message \"{escaped_message}\"'\n        print(cmd)\n        \n        # 返回消息和接收者信息供cron使用\n        print(\"\\n===== 推送信息 =====\")\n        print(f\"CHANNEL: feishu\")\n        print(f\"ACCOUNT: stock\")\n        print(f\"RECEIVERS: {','.join(receivers)}\")\n        print(f\"MESSAGE_START: {message[:100]}...\")\n    else:\n        print(\"\\n无触发预警的股票\")\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773111793936}}
