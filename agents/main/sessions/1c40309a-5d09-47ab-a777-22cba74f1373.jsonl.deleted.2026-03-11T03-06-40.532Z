{"type":"message","id":"bbd71c7b","parentId":"74eeb2ef","timestamp":"2026-03-10T03:05:29.468Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The realtime_daily interface doesn't exist with that name. Let me check what realtime interfaces are available in tushare. According to the documentation link provided (https://tushare.pro/document/2?doc_id=374), I should use the `realtime` or similar interface.\n\nLet me try to find the correct interface name for real-time data.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_8f07780498ab4100b57e7715","name":"exec","arguments":{"command":"cd ~/.openclaw/workspace-main-stock/stock && python3 -c \"\nimport tushare as ts\nimport os\n\ntoken = os.getenv('TUSHARE_TOKEN')\npro = ts.pro_api(token)\n\n# List available interfaces\nprint('Available interfaces containing realtime:')\n# Try common realtime interface names\ninterfaces = ['realtime', 'rt_tick', 'tick', 'quotations', 'quote']\n\nfor iface in interfaces:\n    try:\n        # Try to call it\n        data = pro.query(iface, ts_code='601857.SH')\n        print(f'{iface}: SUCCESS - columns: {list(data.columns) if data is not None else None}')\n        print(f'  Data: {data.head() if data is not None and not data.empty else \\\"Empty\\\"}')\n        break\n    except Exception as e:\n        print(f'{iface}: {str(e)[:60]}')\n\""}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773111921379}}
{"type":"message","id":"3da492ac","parentId":"bbd71c7b","timestamp":"2026-03-10T03:05:30.039Z","message":{"role":"toolResult","toolCallId":"call_8f07780498ab4100b57e7715","toolName":"exec","content":[{"type":"text","text":"Available interfaces containing realtime:\nrealtime: 请指定正确的接口名\nrt_tick: SUCCESS - columns: ['ts_code', 'name', 'trade_time', 'price', 'pre_price', 'high_price', 'open_price', 'low_price', 'close_price', 'volume', 'amount', 'num', 'ask_price1', 'ask_volume1', 'bid_price1', 'bid_volume1', 'ask_price2', 'ask_volume2', 'bid_price2', 'bid_volume2', 'ask_price3', 'ask_volume3', 'bid_price3', 'bid_volume3', 'ask_price4', 'ask_volume4', 'bid_price4', 'bid_volume4', 'ask_price5', 'ask_volume5', 'bid_price5', 'bid_volume5']\n  Data:      ts_code  name           trade_time  ...  ask_volume5  bid_price5  bid_volume5\n0  601857.SH  中国石油  2026-03-10 11:05:28  ...     183000.0       12.04     138600.0\n\n[1 rows x 32 columns]"}],"details":{"status":"completed","exitCode":0,"durationMs":569,"aggregated":"Available interfaces containing realtime:\nrealtime: 请指定正确的接口名\nrt_tick: SUCCESS - columns: ['ts_code', 'name', 'trade_time', 'price', 'pre_price', 'high_price', 'open_price', 'low_price', 'close_price', 'volume', 'amount', 'num', 'ask_price1', 'ask_volume1', 'bid_price1', 'bid_volume1', 'ask_price2', 'ask_volume2', 'bid_price2', 'bid_volume2', 'ask_price3', 'ask_volume3', 'bid_price3', 'bid_volume3', 'ask_price4', 'ask_volume4', 'bid_price4', 'bid_volume4', 'ask_price5', 'ask_volume5', 'bid_price5', 'bid_volume5']\n  Data:      ts_code  name           trade_time  ...  ask_volume5  bid_price5  bid_volume5\n0  601857.SH  中国石油  2026-03-10 11:05:28  ...     183000.0       12.04     138600.0\n\n[1 rows x 32 columns]","cwd":"/home/openclaw/.openclaw/workspace"},"isError":false,"timestamp":1773111930037}}
{"type":"message","id":"f2e867f9","parentId":"3da492ac","timestamp":"2026-03-10T03:06:38.682Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"The `rt_tick` interface works and provides real-time tick data. Now I need to update my script to use this interface instead. Let me rewrite the script to use `rt_tick` for real-time data.","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_0c177251d36b4ee38752d2d6","name":"write","arguments":{"path":"~/.openclaw/workspace-main-stock/stock/get_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n实时股价数据获取脚本\n获取自选股实时数据并应用预警规则\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nimport os\nimport sys\nfrom datetime import datetime, timedelta\n\n# 读取环境变量中的 token\ntoken = os.getenv('TUSHARE_TOKEN')\nif not token:\n    print(\"错误：未找到 TUSHARE_TOKEN 环境变量\")\n    sys.exit(1)\n\n# 初始化 pro 接口\npro = ts.pro_api(token)\n\ndef check_market_status():\n    \"\"\"\n    检查今日是否开盘且未收盘\n    返回：True=未收盘可获取实时数据，False=已收盘或休市\n    \"\"\"\n    today = datetime.now().strftime('%Y%m%d')\n    now = datetime.now()\n    \n    # 检查是否是交易日\n    try:\n        # 获取交易日历\n        cal = pro.trade_cal(exchange='SSE', start_date=today, end_date=today)\n        if cal.empty or cal['is_open'].iloc[0] == 0:\n            print(f\"今日 ({today}) 不是交易日\")\n            return False\n    except Exception as e:\n        print(f\"获取交易日历失败：{e}\")\n        # 如果是周末，直接返回 False\n        if now.weekday() >= 5:\n            print(\"今天是周末，休市\")\n            return False\n    \n    # 检查时间：A 股交易时间 9:30-11:30, 13:00-15:00\n    hour = now.hour\n    minute = now.minute\n    \n    # 下午 3 点后算收盘\n    if hour >= 15:\n        print(\"已收盘 (15:00 后)\")\n        return False\n    # 中午休市时间 (11:30-13:00)\n    if (hour == 11 and minute >= 30) or (hour >= 12 and hour < 13):\n        print(\"中午休市时间 (11:30-13:00)\")\n        return False\n    # 早上 9:30 前\n    if hour < 9 or (hour == 9 and minute < 30):\n        print(\"尚未开盘 (9:30 前)\")\n        return False\n    \n    print(\"市场交易中，可以获取实时数据\")\n    return True\n\ndef get_watchlist():\n    \"\"\"\n    读取自选股列表\n    返回：股票代码列表 (ts_code 格式)\n    \"\"\"\n    watchlist_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/watchlist.txt')\n    stocks = []\n    \n    with open(watchlist_path, 'r', encoding='utf-8') as f:\n        for line in f:\n            line = line.strip()\n            if not line or line.startswith('#'):\n                continue\n            parts = line.split('|')\n            if len(parts) >= 1:\n                code = parts[0].strip()\n                name = parts[1].strip() if len(parts) > 1 else ''\n                \n                # 转换为 ts_code 格式\n                if '.' in code:\n                    # 已经是 ts_code 格式 (如 9866.HK)\n                    ts_code = code.upper()\n                elif code.startswith('6') or code.startswith('9') or code.startswith('5'):\n                    # 沪市\n                    ts_code = code + '.SH'\n                elif code.startswith('0') or code.startswith('3'):\n                    # 深市\n                    ts_code = code + '.SZ'\n                else:\n                    # 美股等\n                    ts_code = code.upper()\n                \n                stocks.append({'ts_code': ts_code, 'name': name, 'original_code': code})\n    \n    return stocks\n\ndef get_realtime_data(stocks):\n    \"\"\"\n    获取实时行情数据\n    使用 rt_tick 接口获取实时 tick 数据\n    \"\"\"\n    all_data = []\n    \n    # 分离 A 股和港股/美股\n    a_stocks = [s for s in stocks if s['ts_code'].endswith('.SH') or s['ts_code'].endswith('.SZ')]\n    hk_stocks = [s for s in stocks if s['ts_code'].endswith('.HK')]\n    us_stocks = [s for s in stocks if not (s['ts_code'].endswith('.SH') or s['ts_code'].endswith('.SZ') or s['ts_code'].endswith('.HK'))]\n    \n    # 获取 A 股实时数据 - 使用 rt_tick 接口\n    if a_stocks:\n        try:\n            # 批量获取，每次最多 50 只 (rt_tick 可能不支持批量)\n            for stock in a_stocks:\n                try:\n                    data = pro.query('rt_tick', ts_code=stock['ts_code'])\n                    if data is not None and not data.empty:\n                        row = data.iloc[0]\n                        row['stock_name'] = stock['name']\n                        all_data.append(row)\n                        print(f\"A 股 {stock['ts_code']} ({stock['name']}) 数据获取成功\")\n                except Exception as e:\n                    print(f\"A 股 {stock['ts_code']} 获取失败：{e}\")\n        except Exception as e:\n            print(f\"获取 A 股实时数据失败：{e}\")\n    \n    # 获取港股实时数据 - 使用 hk_tick 或类似接口\n    if hk_stocks:\n        try:\n            for stock in hk_stocks:\n                try:\n                    # 尝试获取港股实时数据\n                    data = pro.query('hk_tick', ts_code=stock['ts_code'])\n                    if data is not None and not data.empty:\n                        row = data.iloc[0]\n                        row['stock_name'] = stock['name']\n                        all_data.append(row)\n                        print(f\"港股 {stock['ts_code']} ({stock['name']}) 数据获取成功\")\n                except Exception as e:\n                    print(f\"港股 {stock['ts_code']} 获取失败：{e}\")\n        except Exception as e:\n            print(f\"获取港股实时数据失败：{e}\")\n    \n    # 获取美股实时数据\n    if us_stocks:\n        try:\n            for stock in us_stocks:\n                try:\n                    # 尝试获取美股实时数据\n                    data = pro.query('us_tick', ts_code=stock['ts_code'])\n                    if data is not None and not data.empty:\n                        row = data.iloc[0]\n                        row['stock_name'] = stock['name']\n                        all_data.append(row)\n                        print(f\"美股 {stock['ts_code']} ({stock['name']}) 数据获取成功\")\n                except Exception as e:\n                    print(f\"美股 {stock['ts_code']} 获取失败：{e}\")\n        except Exception as e:\n            print(f\"获取美股实时数据失败：{e}\")\n    \n    return pd.DataFrame(all_data) if all_data else pd.DataFrame()\n\ndef format_realtime_data(df, stocks):\n    \"\"\"\n    格式化实时数据为所需格式\n    \"\"\"\n    if df.empty:\n        return []\n    \n    result = []\n    timestamp = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n    \n    for _, row in df.iterrows():\n        ts_code = row.get('ts_code', '')\n        code = ts_code.split('.')[0] if '.' in ts_code else ts_code\n        \n        # 获取股票名称\n        name = row.get('stock_name', row.get('name', ''))\n        \n        # 获取价格数据 - rt_tick 接口字段\n        price = row.get('price', 0) or row.get('close_price', 0)\n        pre_price = row.get('pre_price', 0)\n        \n        # 计算涨跌幅\n        if pre_price > 0 and price > 0:\n            pct_chg = ((price - pre_price) / pre_price) * 100\n        else:\n            pct_chg = row.get('pct_chg', 0)\n        \n        # 计算涨跌额\n        price_change = price - pre_price if pre_price > 0 else 0\n        \n        # 格式化涨跌幅\n        if pct_chg >= 0:\n            change_pct_str = f\"+{pct_chg:.2f}%\"\n        else:\n            change_pct_str = f\"{pct_chg:.2f}%\"\n        \n        result.append({\n            'code': code,\n            'name': name,\n            'price': price,\n            'change_pct': pct_chg,\n            'change_pct_str': change_pct_str,\n            'price_change': price_change,\n            'price_change_str': f\"¥{price_change:.2f}\",\n            'time': timestamp\n        })\n    \n    return result\n\ndef check_alert_rules(data):\n    \"\"\"\n    根据预警规则过滤数据\n    通用规则：\n    - 下跌 > 3% → 触发\n    - 上涨 > 5% → 触发\n    \n    个股专属规则：\n    中国石油 (601857.SH):\n    - 涨幅 > 2% → 触发\n    - 跌幅 > 1% → 触发\n    \"\"\"\n    alerts = []\n    \n    for item in data:\n        code = item['code']\n        change_pct = item['change_pct']\n        triggered = False\n        reason = \"\"\n        \n        # 检查是否是中国石油\n        if code == '601857':\n            # 中国石油专属规则\n            if change_pct > 2:\n                triggered = True\n                reason = \"🟢 涨幅 > 2%\"\n            elif change_pct < -1:\n                triggered = True\n                reason = \"🔴 跌幅 > 1%\"\n        else:\n            # 通用规则\n            if change_pct < -3:\n                triggered = True\n                reason = \"📉 下跌 > 3%\"\n            elif change_pct > 5:\n                triggered = True\n                reason = \"📈 上涨 > 5%\"\n        \n        if triggered:\n            item['alert_reason'] = reason\n            alerts.append(item)\n    \n    # 按涨跌幅排序\n    alerts.sort(key=lambda x: x['change_pct'], reverse=True)\n    \n    return alerts\n\ndef save_to_file(data, filepath):\n    \"\"\"\n    保存数据到文件\n    \"\"\"\n    with open(filepath, 'w', encoding='utf-8') as f:\n        f.write(\"代码 | 名称 | 现价 | 涨跌幅 | 涨跌额 | 时间\\n\")\n        for item in data:\n            line = f\"{item['code']}|{item['name']}|¥{item['price']:.2f}|{item['change_pct_str']}|{item['price_change_str']}|{item['time']}\\n\"\n            f.write(line)\n    \n    print(f\"数据已保存到 {filepath}\")\n\ndef format_alert_message(alerts):\n    \"\"\"\n    格式化预警消息\n    \"\"\"\n    if not alerts:\n        return \"\"\n    \n    # 构建表格形式的消息\n    lines = []\n    lines.append(\"⚠️ 股价预警通知\")\n    lines.append(f\"时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    lines.append(\"\")\n    lines.append(\"| 代码 | 名称 | 当前价 | 涨跌幅 | 涨跌额 | 时间 |\")\n    lines.append(\"|------|------|--------|--------|-------|------|\")\n    \n    for item in alerts:\n        time_short = item['time'].split(' ')[1][:5]  # HH:MM\n        line = f\"| {item['code']} | {item['name']} | ¥{item['price']:.2f} | {item['change_pct_str']} | {item['price_change_str']} | {time_short} |\"\n        lines.append(line)\n    \n    lines.append(\"\")\n    lines.append(\"⚙️ 预警规则\")\n    lines.append(\"• 📉 下跌 > 3% → 触发\")\n    lines.append(\"• 📈 上涨 > 5% → 触发\")\n    lines.append(\"• 中国石油：🟢 涨幅 > 2% / 🔴 跌幅 > 1%\")\n    \n    return \"\\n\".join(lines)\n\ndef main():\n    print(\"===== 实时股价监控 =====\")\n    print(f\"当前时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n    \n    # 步骤 1：检查市场状态\n    if not check_market_status():\n        print(\"市场已收盘或休市，结束本次任务\")\n        return\n    \n    # 步骤 2：清空 realtime-data.txt (已在 cron 配置中处理)\n    \n    # 步骤 3：读取自选股列表\n    stocks = get_watchlist()\n    print(f\"自选股数量：{len(stocks)}\")\n    for s in stocks:\n        print(f\"  - {s['ts_code']} ({s['name']})\")\n    \n    # 步骤 4：获取实时数据\n    print(\"\\n正在获取实时数据...\")\n    df = get_realtime_data(stocks)\n    \n    if df.empty:\n        print(\"未能获取到实时数据\")\n        return\n    \n    # 步骤 5：格式化数据\n    formatted_data = format_realtime_data(df, stocks)\n    print(f\"\\n获取到 {len(formatted_data)} 只股票数据\")\n    \n    # 保存所有数据到文件\n    data_file = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/realtime-data.txt')\n    save_to_file(formatted_data, data_file)\n    \n    # 步骤 6：应用预警规则\n    alerts = check_alert_rules(formatted_data)\n    print(f\"\\n触发预警的股票数量：{len(alerts)}\")\n    \n    if alerts:\n        print(\"\\n预警详情:\")\n        for a in alerts:\n            print(f\"  {a['code']} {a['name']}: {a['change_pct_str']} ({a['alert_reason']})\")\n        \n        # 步骤 7：读取接收者列表\n        receiver_file = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/receiver-list.txt')\n        receivers = []\n        with open(receiver_file, 'r', encoding='utf-8') as f:\n            for line in f:\n                line = line.strip()\n                if line:\n                    receivers.append(line)\n        \n        print(f\"\\n接收者数量：{len(receivers)}\")\n        \n        # 步骤 8：格式化预警消息\n        message = format_alert_message(alerts)\n        print(\"\\n预警消息:\")\n        print(message)\n        \n        # 输出推送命令\n        print(\"\\n===== 推送命令 =====\")\n        targets_args = ' '.join([f'--targets {r}' for r in receivers])\n        # 消息需要转义处理\n        escaped_message = message.replace('\"', '\\\\\"').replace('\\n', '\\\\n')\n        cmd = f'openclaw message broadcast --channel feishu --account stock {targets_args} --message \"{escaped_message}\"'\n        print(cmd)\n        \n        # 返回消息和接收者信息供 cron 使用\n        print(\"\\n===== 推送信息 =====\")\n        print(f\"CHANNEL: feishu\")\n        print(f\"ACCOUNT: stock\")\n        print(f\"RECEIVERS: {','.join(receivers)}\")\n        print(f\"MESSAGE_START: {message[:100]}...\")\n    else:\n        print(\"\\n无触发预警的股票\")\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773111930039}}
