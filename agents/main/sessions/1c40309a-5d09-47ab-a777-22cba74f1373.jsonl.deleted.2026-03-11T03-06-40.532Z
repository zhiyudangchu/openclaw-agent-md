{"type":"message","id":"456aa868","parentId":"25ca063c","timestamp":"2026-03-10T03:04:46.061Z","message":{"role":"toolResult","toolCallId":"call_1a7c5a216ce04adab124bf4f","toolName":"read","content":[{"type":"text","text":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n实时股价数据获取脚本\n获取自选股实时数据并应用预警规则\n\"\"\"\n\nimport tushare as ts\nimport pandas as pd\nimport os\nimport sys\nfrom datetime import datetime, timedelta\n\n# 读取环境变量中的token\ntoken = os.getenv('TUSHARE_TOKEN')\nif not token:\n    print(\"错误：未找到 TUSHARE_TOKEN 环境变量\")\n    sys.exit(1)\n\n# 初始化pro接口\npro = ts.pro_api(token)\n\ndef check_market_status():\n    \"\"\"\n    检查今日是否开盘且未收盘\n    返回：True=未收盘可获取实时数据，False=已收盘或休市\n    \"\"\"\n    today = datetime.now().strftime('%Y%m%d')\n    now = datetime.now()\n    \n    # 检查是否是交易日\n    try:\n        # 获取交易日历\n        cal = pro.trade_cal(exchange='SSE', start_date=today, end_date=today)\n        if cal.empty or cal['is_open'].iloc[0] == 0:\n            print(f\"今日 ({today}) 不是交易日\")\n            return False\n    except Exception as e:\n        print(f\"获取交易日历失败：{e}\")\n        # 如果是周末，直接返回False\n        if now.weekday() >= 5:\n            print(\"今天是周末，休市\")\n            return False\n    \n    # 检查时间：A股交易时间 9:30-11:30, 13:00-15:00\n    hour = now.hour\n    minute = now.minute\n    \n    # 下午3点后算收盘\n    if hour >= 15:\n        print(\"已收盘 (15:00 后)\")\n        return False\n    # 中午休市时间\n    if 11 <= hour < 13:\n        print(\"中午休市时间\")\n        return False\n    # 早上9:30前\n    if hour < 9 or (hour == 9 and minute < 30):\n        print(\"尚未开盘 (9:30 前)\")\n        return False\n\n[322 more lines in file. Use offset=61 to continue.]"}],"isError":false,"timestamp":1773111886059}}
