0-15:00')\n\"\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-122b-a10b","usage":{"input":19827,"output":708,"cacheRead":0,"cacheWrite":0,"totalTokens":20535,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1772849876866}}
