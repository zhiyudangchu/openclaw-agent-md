{"type":"message","id":"4d897aa0","parentId":"0269168d","timestamp":"2026-03-10T05:20:56.940Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"Now I need to create a Python script to fetch real-time stock data using tushare's rt_k interface for all stocks in the watchlist, then save the data to realtime-data.txt.\n","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_c5d0808884094d2da8312f76","name":"write","arguments":{"path":"~/.openclaw/workspace-main-stock/stock/get_realtime_data.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n获取自选股实时数据脚本\n\"\"\"\n\nimport tushare as ts\nimport os\nimport pandas as pd\nfrom datetime import datetime\n\n# 读取环境变量中的 token\ntoken = os.getenv('TUSHARE_TOKEN')\n\n# 初始化 pro 接口\npro = ts.pro_api(token)\n\n# 读取自选股列表\nwatchlist_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/watchlist.txt')\nwith open(watchlist_path, 'r', encoding='utf-8') as f:\n    lines = f.readlines()\n\n# 解析自选股，提取 ts_code 格式\nstock_codes = []\nfor line in lines:\n    line = line.strip()\n    if line and '|' in line:\n        parts = line.split('|')\n        code = parts[0]\n        # 确保代码格式正确（带.SZ/.SH/.HK 等后缀）\n        if '.' in code:\n            stock_codes.append(code)\n        else:\n            # 6 位数字代码，需要添加后缀\n            if code.startswith('6'):\n                stock_codes.append(f\"{code}.SH\")\n            elif code.startswith('0') or code.startswith('3'):\n                stock_codes.append(f\"{code}.SZ\")\n            else:\n                stock_codes.append(code)\n\nprint(f\"自选股数量：{len(stock_codes)}\")\nprint(f\"股票代码：{stock_codes}\")\n\n# 获取实时日线数据\ntry:\n    # 使用 rt_k 接口获取实时数据\n    ts_code_str = ','.join(stock_codes)\n    print(f\"请求代码：{ts_code_str}\")\n    \n    df = pro.rt_k(ts_code=ts_code_str)\n    \n    if df is not None and len(df) > 0:\n        print(f\"获取到 {len(df)} 条数据\")\n        print(df)\n        \n        # 保存到文件\n        output_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/realtime-data.txt')\n        current_time = datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n        \n        with open(output_path, 'w', encoding='utf-8') as f:\n            f.write(f\"数据时间：{current_time}\\n\")\n            f.write(\"=\" * 80 + \"\\n\")\n            \n            for idx, row in df.iterrows():\n                ts_code = row.get('ts_code', '')\n                name = row.get('name', '')\n                pre_close = row.get('pre_close', 0)\n                close = row.get('close', 0)\n                high = row.get('high', 0)\n                low = row.get('low', 0)\n                trade_time = row.get('trade_time', current_time)\n                \n                # 计算涨跌幅\n                if pre_close > 0:\n                    change_pct = ((close - pre_close) / pre_close) * 100\n                    change_amt = close - pre_close\n                else:\n                    change_pct = 0\n                    change_amt = 0\n                \n                # 格式化输出：代码 | 名称 | 当前价 | 昨收 | 最高 | 时间\n                f.write(f\"{ts_code}|{name}|{close:.2f}|{pre_close:.2f}|{high:.2f}|{trade_time}\\n\")\n        \n        print(f\"数据已保存到：{output_path}\")\n    else:\n        print(\"未获取到数据\")\n        \nexcept Exception as e:\n    print(f\"获取数据失败：{e}\")\n    import traceback\n    traceback.print_exc()\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773120045519}}
