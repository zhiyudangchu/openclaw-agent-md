our * 60 + current_minute\n\n# A 股交易时间：9:30-11:30, 13:00-15:00\nmorning_start = 9 * 60 + 30   # 570\nmorning_end = 11 * 60 + 30    # 690\nafternoon_start = 13 * 60     # 780\nafternoon_end = 15 * 60       # 900\n\nis_trading_time = (morning_start <= current_time <= morning_end) or (afternoon_start <= current_time <= afternoon_end)\n\n# 如果是 15:00 之后，检查是否还能获取到当日数据\nif current_time > afternoon_end:\n    print(f\"当前时间 {current_hour}:{current_minute:02d} 已收盘，但仍可获取当日数据\")\n    # 收盘后仍可获取数据，继续执行\nelif not is_trading_time:\n    print(f\"当前时间 {current_hour}:{current_minute:02d} 不在交易时间内\")\n    # 非交易时间也可以获取数据，继续执行\n\n# 构建 ts_code 列表\nts_codes = []\nfor stock in watchlist:\n    code = stock['code']\n    # 处理不同市场的代码格式\n    if code.endswith('.SH') or code.endswith('.SZ') or code.endswith('.HK'):\n        ts_codes.append(code)\n    elif code.isdigit():\n        # A 股代码，需要根据代码判断市场\n        if code.startswith('6') or code.startswith('9'):\n            ts_codes.append(f\"{code}.SH\")\n        elif code.startswith('0') or code.startswith('3'):\n            ts_codes.append(f\"{code}.SZ\")\n        else:\n            ts_codes.append(f\"{code}.SH\")  # 默认 SH\n    else:\n        # 美股或其他\n        ts_codes.append(code)\n\nprint(f\"请求代码：{ts_codes}\")\n\n# 获取实时日线数据\ntry:\n    # 使用实时日线接口 - 根据文档 doc_id=372\n    ts_code_str = ','.join(ts_codes)\n    print(f\"获取实时日线数据：{ts_code_str}\")\n    \n    # 尝试使用 daily 接口获取日线数据\n    df = pro.daily(ts_code=ts_code_str, start_date=today, end_date=today)\n    \n    if df.empty:\n        print(\"未获取到数据，尝试使用其他接口...\")\n        # 尝试使用 stk_factor_daily 接口\n        try:\n            df = pro.stk_factor_daily(ts_code=ts_code_str, trade_date=today)\n        except Exception as e2:\n            print(f\"备用接口也失败：{e2}\")\n            sys.exit(1)\n    \n    print(f\"获取到 {len(df)} 条数据\")\n    print(df)\n    \n    # 保存数据到文件\n    output_path = os.path.expanduser('~/.openclaw/workspace-main-stock/stock/realtime-data.txt')\n    df.to_csv(output_path, index=False, encoding='utf-8')\n    print(f\"数据已保存到：{output_path}\")\n    \nexcept Exception as e:\n    print(f\"获取数据失败：{e}\")\n    import traceback\n    traceback.print_exc()\n    sys.exit(1)\n\nprint(\"数据获取完成\")\n","path":"~/.openclaw/workspace-main-stock/stock/get_realtime_data.py"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-plus","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773129077091}}
