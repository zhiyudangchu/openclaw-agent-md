{"type":"message","id":"27fbd283","parentId":"7d1b88d1","timestamp":"2026-03-10T04:48:05.326Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"网页 HTML 数据难以解析，让我尝试使用新浪财经的实时行情接口，这是一个更简单可靠的股票数据源。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"网页内容太复杂。让我尝试使用新浪财经的接口，这个比较简单：\n\n"},{"type":"toolCall","id":"call_ed5b47b2f3164a3bb0d3dffa","name":"exec","arguments":{"command":"cd /home/openclaw/.openclaw/workspace-main-stock && python3 << 'PYEOF'\nimport requests\nimport re\nfrom datetime import datetime\n\n# 新浪财经实时行情接口\ndef get_sina_stock_data(code):\n    \"\"\"获取单个股票的新浪实时数据\"\"\"\n    # 判断市场\n    if code.endswith('.HK'):\n        # 港股\n        sinacode = 'hk' + code.replace('.HK', '')\n    elif code.endswith('.SH'):\n        sinacode = 'sh' + code.replace('.SH', '')\n    elif code.endswith('.SZ'):\n        sinacode = 'sz' + code.replace('.SZ', '')\n    else:\n        # 根据代码前缀判断\n        if code.startswith('6'):\n            sinacode = 'sh' + code  # 沪市\n        elif code.startswith('0') or code.startswith('3'):\n            sinacode = 'sz' + code  # 深市\n        elif code.startswith('9') or code.startswith('8'):\n            sinacode = 'sz' + code  # 北交所\n        else:\n            return None\n    \n    url = f\"http://hq.sinajs.cn/list={sinacode}\"\n    try:\n        response = requests.get(url, timeout=5)\n        response.encoding = 'gbk'\n        text = response.text\n        \n        # 解析返回数据\n        # var hq_str_sh601857=\"中国石油，12.16,12.18,12.16,12.30,11.78,12.16,12.17,3561456,432871234,...\"\n        match = re.search(r'=\"([^\"]+)\"', text)\n        if match:\n            data_str = match.group(1)\n            parts = data_str.split(',')\n            \n            if len(parts) >= 32:\n                name = parts[0]\n                open_p = float(parts[1]) if parts[1] else 0\n                close_p = float(parts[2]) if parts[2] else 0  # 当前价\n                high = float(parts[3]) if parts[3] else 0\n                low = float(parts[4]) if parts[4] else 0\n                pre_close = float(parts[5]) if parts[5] else 0  # 昨收\n                \n                # 计算涨跌幅和涨跌额\n                if pre_close > 0:\n                    change_amt = close_p - pre_close\n                    change_pct = (change_amt / pre_close) * 100\n                else:\n                    change_amt = 0\n                    change_pct = 0\n                \n                volume = int(parts[8]) if parts[8] else 0\n                amount = float(parts[9]) if parts[9] else 0\n                \n                return {\n                    'code': code,\n                    'name': name,\n                    'current_price': close_p,\n                    'change_pct': change_pct,\n                    'change_amt': change_amt,\n                    'pre_close': pre_close,\n                    'open': open_p,\n                    'high': high,\n                    'low': low,\n                    'volume': volume,\n                    'amount': amount,\n                    'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                }\n    except Exception as e:\n        print(f\"获取 {code} 数据失败：{e}\")\n    return None\n\n# 读取自选股列表\nwatchlist = []\nwith open('stock/watchlist.txt', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            parts = line.split('|')\n            code = parts[0]\n            name = parts[1] if len(parts) > 1 else ''\n            watchlist.append({'code': code, 'name': name})\n\n# 获取实时数据\nresults = []\nfor stock in watchlist:\n    code = stock['code']\n    data = get_sina_stock_data(code)\n    \n    if data:\n        results.append(data)\n        print(f\"{data['name']} ({data['code']}): ¥{data['current_price']:.2f}, {data['change_pct']:+.2f}%, {data['change_amt']:+.2f}\")\n    else:\n        print(f\"{code} - 无数据\")\n\nprint(f\"\\n共获取 {len(results)} 只股票有效数据\")\n\n# 保存到文件\nwith open('stock/realtime-data.txt', 'w') as f:\n    f.write(\"code|name|current_price|change_pct|change_amt|pre_close|open|high|low|volume|amount|timestamp\\n\")\n    for r in results:\n        f.write(f\"{r['code']}|{r['name']}|{r['current_price']:.2f}|{r['change_pct']:.2f}|{r['change_amt']:.2f}|{r['pre_close']:.2f}|{r['open']:.2f}|{r['high']:.2f}|{r['low']:.2f}|{r['volume']}|{r['amount']:.2f}|{r['timestamp']}\\n\")\n\nprint(\"数据已保存到 stock/realtime-data.txt\")\nPYEOF\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773118062474}}
