{"type":"message","id":"8e47491e","parentId":"0624521f","timestamp":"2026-03-10T04:49:11.144Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"腾讯接口测试成功，但数据解析需要修正字段映射，现在编写完整脚本获取所有自选股数据并保存。","thinkingSignature":"reasoning_content"},{"type":"text","text":"腾讯接口可用！但我看到数据解析有些问题。让我修正字段映射并获取所有股票数据：\n\n"},{"type":"toolCall","id":"call_f34f65f5bc7f4ad2b2427d34","name":"exec","arguments":{"command":"cd /home/openclaw/.openclaw/workspace-main-stock && python3 << 'PYEOF'\nimport requests\nimport re\nfrom datetime import datetime\n\n# 腾讯实时行情接口\ndef get_qq_stock_data(code):\n    \"\"\"获取单个股票的腾讯实时数据\"\"\"\n    # 判断市场\n    if code.endswith('.HK'):\n        sinacode = 'hk' + code.replace('.HK', '')\n    elif code.endswith('.SH'):\n        sinacode = 'sh' + code.replace('.SH', '')\n    elif code.endswith('.SZ'):\n        sinacode = 'sz' + code.replace('.SZ', '')\n    else:\n        if code.startswith('6'):\n            sinacode = 'sh' + code\n        elif code.startswith('0') or code.startswith('3'):\n            sinacode = 'sz' + code\n        elif code.startswith('9') or code.startswith('8'):\n            sinacode = 'sz' + code\n        else:\n            return None\n    \n    url = f\"http://qt.gtimg.cn/q={sinacode}\"\n    headers = {\n        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n        'Referer': 'http://stockapp.finance.qq.com/'\n    }\n    \n    try:\n        response = requests.get(url, headers=headers, timeout=5)\n        response.encoding = 'gbk'\n        text = response.text\n        \n        match = re.search(r'=\"([^\"]+)\"', text)\n        if match:\n            data_str = match.group(1)\n            parts = data_str.split('~')\n            \n            if len(parts) >= 50:\n                # 根据实际返回解析：v_sh601857=\"1~中国石油~601857~12.16~12.92~12.18~...\"\n                # parts[0]: 未知，parts[1]: 名称，parts[2]: 代码\n                # parts[3]: 当前价，parts[4]: 涨跌额，parts[5]: 昨收\n                # parts[32]: 涨跌幅百分比 (带符号)\n                name = parts[1]\n                current_price = float(parts[3]) if parts[3] else 0\n                change_amt = float(parts[4]) if parts[4] else 0\n                pre_close = float(parts[5]) if parts[5] else 0\n                \n                # 从 parts[32] 获取涨跌幅百分比\n                change_pct = float(parts[32]) if len(parts) > 32 and parts[32] else 0\n                high = float(parts[33]) if len(parts) > 33 and parts[33] else 0\n                low = float(parts[34]) if len(parts) > 34 and parts[34] else 0\n                open_p = float(parts[6]) if len(parts) > 6 and parts[6] else current_price  # 今开\n                volume = float(parts[7]) if len(parts) > 7 and parts[7] else 0  # 成交量 (手)\n                amount = float(parts[37]) if len(parts) > 37 and parts[37] else 0  # 成交额 (万)\n                \n                return {\n                    'code': code,\n                    'name': name,\n                    'current_price': current_price,\n                    'change_pct': change_pct,\n                    'change_amt': change_amt,\n                    'pre_close': pre_close,\n                    'open': open_p,\n                    'high': high,\n                    'low': low,\n                    'volume': int(volume * 100),  # 手转股\n                    'amount': amount * 10000,  # 万转元\n                    'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                }\n    except Exception as e:\n        print(f\"获取 {code} 数据失败：{e}\")\n    return None\n\n# 读取自选股列表\nwatchlist = []\nwith open('stock/watchlist.txt', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            parts = line.split('|')\n            code = parts[0]\n            name = parts[1] if len(parts) > 1 else ''\n            watchlist.append({'code': code, 'name': name})\n\n# 获取实时数据\nresults = []\nfor stock in watchlist:\n    code = stock['code']\n    data = get_qq_stock_data(code)\n    \n    if data:\n        results.append(data)\n        print(f\"{data['name']} ({data['code']}): ¥{data['current_price']:.2f}, {data['change_pct']:+.2f}%, {data['change_amt']:+.2f}\")\n    else:\n        print(f\"{code} - 无数据\")\n\nprint(f\"\\n共获取 {len(results)} 只股票有效数据\")\n\n# 保存到文件\nwith open('stock/realtime-data.txt', 'w') as f:\n    f.write(\"code|name|current_price|change_pct|change_amt|pre_close|open|high|low|volume|amount|timestamp\\n\")\n    for r in results:\n        f.write(f\"{r['code']}|{r['name']}|{r['current_price']:.2f}|{r['change_pct']:.2f}|{r['change_amt']:.2f}|{r['pre_close']:.2f}|{r['open']:.2f}|{r['high']:.2f}|{r['low']:.2f}|{r['volume']}|{r['amount']:.2f}|{r['timestamp']}\\n\")\n\nprint(\"\\n数据已保存到 stock/realtime-data.txt\")\nPYEOF\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773118127086}}
