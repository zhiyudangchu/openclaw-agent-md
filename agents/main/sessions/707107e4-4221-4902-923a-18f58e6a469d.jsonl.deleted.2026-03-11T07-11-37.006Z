{"type":"message","id":"bc13159d","parentId":"f130f693","timestamp":"2026-03-10T04:48:46.161Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"新浪和东方财富接口都失败了，让我尝试使用腾讯的股票行情 API 来获取实时数据。\n","thinkingSignature":"reasoning_content"},{"type":"text","text":"新浪接口被阻止了。让我尝试使用腾讯的接口：\n\n"},{"type":"toolCall","id":"call_b864b83a6e914a80b9a93dd1","name":"exec","arguments":{"command":"cd /home/openclaw/.openclaw/workspace-main-stock && python3 << 'PYEOF'\nimport requests\nimport re\nfrom datetime import datetime\n\n# 腾讯实时行情接口\ndef get_qq_stock_data(code):\n    \"\"\"获取单个股票的腾讯实时数据\"\"\"\n    # 判断市场\n    if code.endswith('.HK'):\n        sinacode = 'hk' + code.replace('.HK', '')\n    elif code.endswith('.SH'):\n        sinacode = 'sh' + code.replace('.SH', '')\n    elif code.endswith('.SZ'):\n        sinacode = 'sz' + code.replace('.SZ', '')\n    else:\n        if code.startswith('6'):\n            sinacode = 'sh' + code\n        elif code.startswith('0') or code.startswith('3'):\n            sinacode = 'sz' + code\n        elif code.startswith('9') or code.startswith('8'):\n            sinacode = 'sz' + code\n        else:\n            return None\n    \n    url = f\"http://qt.gtimg.cn/q={sinacode}\"\n    headers = {\n        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n        'Referer': 'http://stockapp.finance.qq.com/'\n    }\n    \n    try:\n        response = requests.get(url, headers=headers, timeout=5)\n        response.encoding = 'gbk'\n        text = response.text\n        \n        # 解析：v_sh601857=\"51~中国石油~601857~12.16~12.18~12.16~~12.30~11.78~12.17~12.16~3561456...\"\n        match = re.search(r'=\"([^\"]+)\"', text)\n        if match:\n            data_str = match.group(1)\n            parts = data_str.split('~')\n            \n            if len(parts) >= 30:\n                # parts[1]: 名称，parts[3]: 当前价，parts[32]: 涨跌幅，parts[4]: 涨跌额\n                name = parts[1]\n                current_price = float(parts[3]) if parts[3] else 0\n                change_amt = float(parts[4]) if parts[4] else 0\n                pre_close = float(parts[5]) if parts[5] else 0\n                open_p = float(parts[6]) if parts[6] else 0\n                high = float(parts[33]) if len(parts) > 33 and parts[33] else 0\n                low = float(parts[34]) if len(parts) > 34 and parts[34] else 0\n                volume = float(parts[7]) if parts[7] else 0\n                amount = float(parts[37]) if len(parts) > 37 and parts[37] else 0\n                \n                # 计算涨跌幅百分比\n                if pre_close > 0:\n                    change_pct = (change_amt / pre_close) * 100\n                else:\n                    change_pct = 0\n                \n                return {\n                    'code': code,\n                    'name': name,\n                    'current_price': current_price,\n                    'change_pct': change_pct,\n                    'change_amt': change_amt,\n                    'pre_close': pre_close,\n                    'open': open_p,\n                    'high': high,\n                    'low': low,\n                    'volume': int(volume),\n                    'amount': amount,\n                    'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n                }\n    except Exception as e:\n        print(f\"获取 {code} 数据失败：{e}\")\n    return None\n\n# 测试\ncode = \"601857\"\ndata = get_qq_stock_data(code)\nif data:\n    print(f\"测试成功：{data}\")\nelse:\n    print(\"测试失败\")\n\n# 读取原始返回\nurl = \"http://qt.gtimg.cn/q=sh601857\"\nheaders = {\n    'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n}\nresponse = requests.get(url, headers=headers, timeout=5)\nresponse.encoding = 'gbk'\nprint(f\"\\n原始返回：{response.text[:500]}\")\nPYEOF\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"