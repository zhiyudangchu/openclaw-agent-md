{"type":"message","id":"a8b32401","parentId":"311069cb","timestamp":"2026-03-10T04:46:15.346Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"既然 Tushare token 验证失败，我需要使用东方财富的实时行情接口来获取自选股数据，编写完整的 Python 脚本来获取数据并保存到 realtime-data.txt。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"call_f5ebe640b7244a6dba9dcb0f","name":"exec","arguments":{"command":"cd /home/openclaw/.openclaw/workspace-main-stock && python3 << 'PYEOF'\nimport requests\nimport re\nfrom datetime import datetime\n\n# 东方财富实时行情接口\n# 格式：http://push2.eastmoney.com/api/qt/stock/get?invt=2&fltt=1&fields=f43,f44,f45,f46,f47,f48,f49,f50,f51,f52,f57,f58,f84,f85,f86,f87,f117,f118,f119,f120,f121,f122,f123,f124,f125,f126,f127,f128,f129,f130,f131,f132,f133,f134,f135,f136,f137,f138,f139,f140,f141,f142,f143,f144,f145,f146,f147,f148,f149,f150,f151,f152,f153,f154,f155,f156,f157,f158,f159,f160,f161,f162,f163,f164,f165,f166,f167,f168,f169,f170,f171,f172,f173,f174,f175,f176,f177,f178,f179,f180,f181,f182,f183,f184,f185,f186,f187,f188,f189,f190,f191,f192,f193,f194,f195,f196,f197,f198,f199,f200&secid={secid}\n\ndef get_stock_data(code):\n    \"\"\"获取单个股票的实时数据\"\"\"\n    # 判断市场\n    if code.endswith('.HK'):\n        secid = code.replace('.HK', '')\n        market = '116'  # 港股\n    elif code.endswith('.SH'):\n        secid = code.replace('.SH', '')\n        market = '1'  # 沪市\n    elif code.endswith('.SZ'):\n        secid = code.replace('.SZ', '')\n        market = '0'  # 深市\n    else:\n        # 根据代码前缀判断\n        if code.startswith('6'):\n            secid = code\n            market = '1'  # 沪市\n        elif code.startswith('0') or code.startswith('3'):\n            secid = code\n            market = '0'  # 深市\n        elif code.startswith('9') or code.startswith('8'):\n            secid = code\n            market = '0'  # 北交所\n        else:\n            # 美股等\n            return None\n    \n    secid_full = f\"{market}.{secid}\"\n    url = f\"http://push2.eastmoney.com/api/qt/stock/get?invt=2&fltt=1&fields=f43,f44,f45,f46,f47,f48,f49,f50,f51,f52,f57,f58,f84,f85,f86,f87,f117,f118,f119,f120,f121,f122,f123,f124,f125,f126,f127,f128,f129,f130,f131,f132,f133,f134,f135,f136,f137,f138,f139,f140,f141,f142,f143,f144,f145,f146,f147,f148,f149,f150,f151,f152,f153,f154,f155,f156,f157,f158,f159,f160,f161,f162,f163,f164,f165,f166,f167,f168,f169,f170,f171,f172,f173,f174,f175,f176,f177,f178,f179,f180,f181,f182,f183,f184,f185,f186,f187,f188,f189,f190,f191,f192,f193,f194,f195,f196,f197,f198,f199,f200&secid={secid_full}\"\n    \n    try:\n        response = requests.get(url, timeout=5)\n        data = response.json()\n        if data.get('data'):\n            return data['data']\n    except Exception as e:\n        print(f\"获取 {code} 数据失败：{e}\")\n    return None\n\n# 读取自选股列表\nwatchlist = []\nwith open('stock/watchlist.txt', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            parts = line.split('|')\n            code = parts[0]\n            name = parts[1] if len(parts) > 1 else ''\n            watchlist.append({'code': code, 'name': name})\n\n# 获取实时数据\nresults = []\nfor stock in watchlist:\n    code = stock['code']\n    expected_name = stock['name']\n    data = get_stock_data(code)\n    \n    if data:\n        # f57: 代码，f58: 名称，f43: 最新价，f146: 涨跌幅，f147: 涨跌额，f48: 昨收，f46: 今开，f44: 最高，f45: 最低，f47: 成交量，f49: 成交额\n        current_price = data.get('f43', 0) / 100 if data.get('f43') else 0\n        change_pct = data.get('f146', 0) / 100 if data.get('f146') else 0\n        change_amt = data.get('f147', 0) / 100 if data.get('f147') else 0\n        pre_close = data.get('f48', 0) / 100 if data.get('f48') else 0\n        open_price = data.get('f46', 0) / 100 if data.get('f46') else 0\n        high = data.get('f44', 0) / 100 if data.get('f44') else 0\n        low = data.get('f45', 0) / 100 if data.get('f45') else 0\n        volume = data.get('f47', 0)\n        amount = data.get('f49', 0)\n        name = data.get('f58', expected_name)\n        ts_code = data.get('f57', code)\n        \n        results.append({\n            'code': ts_code,\n            'name': name,\n            'current_price': current_price,\n            'change_pct': change_pct,\n            'change_amt': change_amt,\n            'pre_close': pre_close,\n            'open': open_price,\n            'high': high,\n            'low': low,\n            'volume': volume,\n            'amount': amount,\n            'timestamp': datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n        })\n        print(f\"{name} ({ts_code}): ¥{current_price:.2f}, {change_pct:+.2f}%, {change_amt:+.2f}\")\n    else:\n        print(f\"{code} - 无数据\")\n\nprint(f\"\\n共获取 {len(results)} 只股票数据\")\nPYEOF\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773117941846}}
