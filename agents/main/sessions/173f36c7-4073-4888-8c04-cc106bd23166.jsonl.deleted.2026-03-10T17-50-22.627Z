e.text, 'html.parser')\\n    \\n    # 查找关键信息\\n    title = soup.find('h1') or soup.find('title')\\n    if title:\\n        print(f\\\"📌 {title.get_text().strip()}\\\")\\n    \\n    # 查找财务数据表格\\n    tables = soup.find_all('table')\\n    for table in tables[:2]:\\n        text = table.get_text()[:500]\\n        if '净利润' in text or '营业收入' in text:\\n            print(f\\\"\\\\n{text}\\\")\\n            \\nexcept Exception as e:\\n    print(f\\\"获取失败：{e}\\\")\\n    print(\\\"\\\\n尝试另一种方式...\\\")\\n    \\n    # 试试 F10 页面\\n    url2 = f\\\"https://basic.10jqka.com.cn/{stock_code}/fundamental.html\\\"\\n    try:\\n        resp = requests.get(url2, headers=headers, timeout=10)\\n        resp.encoding = 'utf-8'\\n        soup = BeautifulSoup(resp.text, 'html.parser')\\n        \\n        # 提取每股收益、净资产等指标\\n        items = soup.select('.item, .data, span[data-field]')\\n        print(\\\"📊 主要财务指标:\\\")\\n        for item in items[:10]:\\n            text = item.get_text().strip()\\n            if text:\\n                print(f\\\"  {text}\\\")\\n    except Exception as e2:\\n        print(f\\\"仍无法获取，建议手动访问同花顺查看\\\")\\nEOF\\n\"}}],\"api\":\"openai-completions\",\"provider\":\"custom-dashscope-aliyuncs-com\",\"model\":\"qwen3.5-122b-a10b\",\"usage\":{\"input\":104106,\"output\":579,\"cacheRead\":0,\"cacheWrite\":0,\"totalTokens\":104685,\"cost\":{\"input\":0,\"output\":0,\"cacheRead\":0,\"cacheWrite\":0,\"total\":0}},\"stopReason\":\"toolUse\",\"timestamp\":1772817625240}}\n{\"type\":\"message\",\"id\":\"77c68f47\",\"parentId\":\"38877e2e\",\"timestamp\":\"2026-03-06T17:20:32.734Z\",\"message\":{\"role\":\"toolResult\",\"toolCallId\":\"call_5c4574f2953d47658e4214d4\",\"toolName\":\"exec\",\"content\":[{\"type\":\"text\",\"text\":\"=== 宗申动力 (000769) 基本资料 ===\\n\\n获取失败：HTTPSConnectionPool(host='f10.market.10jqka.com.cn', port=443): Max retries exceeded with url: /fckj/000769/ (Caused by NameResolutionError(\\\"<urllib3.connection.HTTPSConnection object at 0x7febd6961fd0>: Failed 