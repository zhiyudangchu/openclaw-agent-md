{"type":"message","id":"6820fcf0","parentId":"cc8b35d0","timestamp":"2026-03-09T14:43:14.591Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"既然 Tushare 方法耗时太长，让我改用 Python + requests 直接访问同花顺 API 来获取实时股价数据。","thinkingSignature":"reasoning_content"},{"type":"text","text":"让我使用更简单的方法，直接用 Python+requests 访问同花顺的 API：\n\n"},{"type":"toolCall","id":"call_ed8635ae1f694dda913f4cb9","name":"exec","arguments":{"command":"python3 << 'EOF'\nimport json\nimport time\nfrom datetime import datetime\n\ndef fetch_stock_data(code):\n    \"\"\"从同花顺 iFinD API 获取股票数据\"\"\"\n    try:\n        import urllib.request\n        import urllib.parse\n        \n        # 尝试获取行情数据\n        url = f\"https://stockpage.10jqka.com.cn/{code}/\"\n        \n        req = urllib.request.Request(url, headers={\n            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',\n            'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',\n            'Accept-Language': 'zh-CN,zh;q=0.9,en;q=0.8',\n        })\n        \n        with urllib.request.urlopen(req, timeout=10) as response:\n            html = response.read().decode('utf-8')\n            \n            # 查找价格信息 - 搜索当前价模式\n            import re\n            \n            # 尝试提取价格（不同页面格式可能不同）\n            price_match = re.search(r'class=\"current\".*?>(\\d+\\.?\\d*)', html)\n            if not price_match:\n                price_match = re.search(r'\"current\":(\\d+\\.?\\d*)', html)\n            \n            change_match = re.search(r'\"change_pct\":(-?\\d+\\.?\\d*)', html)\n            \n            if price_match and change_match:\n                price = float(price_match.group(1))\n                pct_chg = float(change_match.group(1))\n                \n                return {\n                    'price': price,\n                    'pct_chg': pct_chg\n                }\n    except Exception as e:\n        print(f\"错误 {code}: {e}\")\n    \n    return None\n\n# 读取自选股\nwatchlist = []\nwith open('/home/openclaw/.openclaw/workspace-main-stock/stock/watchlist.txt', 'r') as f:\n    for line in f:\n        line = line.strip()\n        if line and '|' in line:\n            parts = line.split('|')\n            watchlist.append((parts[0], parts[1]))\n\nresults = []\nfor code, name in watchlist:\n    print(f\"正在获取 {code} - {name}...\")\n    data = fetch_stock_data(code)\n    \n    if data:\n        results.append({\n            'code': code,\n            'name': name,\n            'price': data['price'],\n            'pct_chg': data['pct_chg'],\n            'timestamp': datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")\n        })\n        sign = '+' if data['pct_chg'] >= 0 else ''\n        print(f\"  ✅ ¥{data['price']:.2f} ({sign}{data['pct_chg']:.2f}%)\")\n    else:\n        print(f\"  ⚠️ 数据获取失败\")\n    \n    time.sleep(2)\n\nprint(f\"\\n完成！共获取 {len(results)} 条数据\")\n\n# 保存到文件\noutput_file = '/home/openclaw/workspace-main-stock/stock/realtime-data.txt'\nwith open(output_file, 'w', encoding='utf-8') as f:\n    f.write(\"| 代码 | 名称 | 当前价 | 涨跌幅 | 涨跌额 | 时间 |\\n\")\n    f.write(\"|------|------|--------|--------|-------|------|\\n\")\n    \n    # 按涨跌幅排序（绝对值）\n    sorted_results = sorted(results, key=lambda x: abs(x['pct_chg']), reverse=True)\n    \n    for r in sorted_results:\n        price_change = r['price'] * r['pct_chg'] / 100\n        sign = '+' if r['pct_chg'] >= 0 else ''\n        f.write(f\"| {r['code']} | {r['name']} | ¥{r['price']:.2f} | {sign}{r['pct_chg']:.2f}% | ¥{price_change:.2f} | {r['timestamp'].split()[1]} |\\n\")\n\nprint(f\"数据已保存到 {output_file}\")\nEOF\n","timeout":120}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-35b-a3b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773067387894}}
