{"type":"message","id":"d17a2de9","parentId":"ba58bc7c","timestamp":"2026-03-10T02:47:20.356Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"现在让我根据预警规则过滤数据并创建推送消息。","thinkingSignature":"reasoning_content"},{"type":"text","text":"现在让我根据预警规则过滤数据并创建推送消息：\n\n"},{"type":"toolCall","id":"call_ce784a9eb9154e239bb460b8","name":"write","arguments":{"path":"/home/openclaw/.openclaw/workspace-main-stock/stock/filter_and_push.py","content":"#!/usr/bin/env python3\n\"\"\"\n根据预警规则过滤数据并推送\n\"\"\"\n\nimport os\nimport subprocess\nfrom datetime import datetime\n\nDATA_FILE = os.path.expanduser(\"~/.openclaw/workspace-main-stock/stock/realtime-data.txt\")\nRECEIVER_FILE = os.path.expanduser(\"~/.openclaw/workspace-main-stock/stock/receiver-list.txt\")\n\n# 预警规则\n# 通用规则：下跌 > 3% 或 上涨 > 5%\n# 中国石油专属：涨幅 > 2% 或 跌幅 > 1%\n\ndef load_receivers():\n    \"\"\"加载接收者列表\"\"\"\n    receivers = []\n    if os.path.exists(RECEIVER_FILE):\n        with open(RECEIVER_FILE, 'r', encoding='utf-8') as f:\n            for line in f:\n                line = line.strip()\n                if line:\n                    receivers.append(line)\n    return receivers\n\ndef check_alert_rule(code, name, pct_chg):\n    \"\"\"检查是否触发预警规则\"\"\"\n    # 中国石油专属规则\n    if code == '601857' or name == '中国石油':\n        if pct_chg > 2:\n            return True, '🟢 涨幅 > 2%'\n        if pct_chg < -1:\n            return True, '🔴 跌幅 > 1%'\n    else:\n        # 通用规则\n        if pct_chg < -3:\n            return True, '📉 下跌 > 3%'\n        if pct_chg > 5:\n            return True, '📈 上涨 > 5%'\n    \n    return False, None\n\ndef load_and_filter_data():\n    \"\"\"加载数据并过滤\"\"\"\n    alerts = []\n    \n    if not os.path.exists(DATA_FILE):\n        return alerts\n    \n    with open(DATA_FILE, 'r', encoding='utf-8') as f:\n        lines = f.readlines()\n    \n    # 跳过标题行\n    for line in lines[1:]:\n        line = line.strip()\n        if not line:\n            continue\n        \n        parts = line.split('|')\n        if len(parts) >= 5:\n            code = parts[0]\n            name = parts[1]\n            price_str = parts[2].replace('¥', '')\n            pct_chg_str = parts[3].replace('%', '')\n            price_change = parts[4]\n            time_str = parts[5] if len(parts) > 5 else ''\n            \n            try:\n                price = float(price_str)\n                pct_chg = float(pct_chg_str)\n                \n                triggered, reason = check_alert_rule(code, name, pct_chg)\n                if triggered:\n                    alerts.append({\n                        'code': code,\n                        'name': name,\n                        'price': price,\n                        'pct_chg': pct_chg,\n                        'price_change': price_change,\n                        'time': time_str,\n                        'reason': reason\n                    })\n            except (ValueError, IndexError) as e:\n                print(f\"解析错误：{line} - {e}\")\n    \n    return alerts\n\ndef format_alert_message(alerts):\n    \"\"\"格式化预警消息\"\"\"\n    if not alerts:\n        return None\n    \n    # 按涨跌幅绝对值排序\n    alerts.sort(key=lambda x: abs(x['pct_chg']), reverse=True)\n    \n    # 构建表格\n    lines = [\n        \"⚠️ *股价预警通知*\",\n        f\"时间：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\",\n        \"\",\n        \"| 代码 | 名称 | 当前价 | 涨跌幅 | 涨跌额 | 时间 |\",\n        \"|------|------|--------|--------|-------|------|\"\n    ]\n    \n    for a in alerts[:10]:  # 最多 10 条\n        change_symbol = \"🔴\" if a['pct_chg'] >= 0 else \"🟢\"\n        lines.append(f\"| {a['code']} | {a['name']} | ¥{a['price']:.2f} | {a['pct_chg']:+.2f}% | {a['price_change']} | {a['time'].split(' ')[1][:5]} |\")\n    \n    lines.extend([\n        \"\",\n        \"⚙️ 预警规则\",\n        \"• 📉 下跌 > 3% → 触发\",\n        \"• 📈 上涨 > 5% → 触发\",\n        \"• 中国石油：🟢 涨幅 > 2% | 🔴 跌幅 > 1%\"\n    ])\n    \n    return '\\n'.join(lines)\n\ndef send_alert(message):\n    \"\"\"发送预警消息\"\"\"\n    if not message:\n        print(\"无预警数据，不发送消息\")\n        return\n    \n    receivers = load_receivers()\n    if not receivers:\n        print(\"无接收者列表\")\n        return\n    \n    # 构建命令\n    cmd = [\n        'openclaw', 'message', 'broadcast',\n        '--channel', 'feishu',\n        '--account', 'stock'\n    ]\n    \n    for receiver in receivers:\n        cmd.extend(['--targets', receiver])\n    \n    cmd.extend(['--message', message])\n    \n    print(f\"发送消息给 {len(receivers)} 个用户...\")\n    print(f\"命令：{' '.join(cmd)}\")\n    \n    try:\n        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)\n        if result.returncode == 0:\n            print(\"✅ 消息发送成功\")\n        else:\n            print(f\"❌ 发送失败：{result.stderr}\")\n    except Exception as e:\n        print(f\"❌ 执行错误：{e}\")\n\ndef main():\n    print(f\"🔍 开始过滤预警数据 - {datetime.now()}\")\n    \n    alerts = load_and_filter_data()\n    \n    print(f\"找到 {len(alerts)} 条预警数据\")\n    \n    if alerts:\n        for a in alerts:\n            print(f\"  - {a['code']} {a['name']}: {a['pct_chg']:+.2f}% ({a['reason']})\")\n    \n    message = format_alert_message(alerts)\n    send_alert(message)\n\nif __name__ == \"__main__\":\n    main()\n"}}],"api":"openai-completions","provider":"custom-dashscope-aliyuncs-com","model":"qwen3.5-397b-a17b","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773110777846}}
